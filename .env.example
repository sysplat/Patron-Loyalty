# ──────────────────────────────────────────────────
# Patron Loyalty (LMS) Environment Configuration
# Copy to .env and fill in your values
# Sibling QlessQ queue product: ../QMS
# ──────────────────────────────────────────────────

# ─── General ──────────────────────────────────────
NODE_ENV=development
PORT=4000
APP_URL=http://localhost:3003
LOYALTY_URL=http://localhost:3003
API_URL=http://localhost:4000
# Optional comma-separated extra frontend origins for production CORS.
# Include admin + loyalty Railway hosts in production, e.g.:
# APP_ALLOWED_ORIGINS=https://staging.example.com,https://admin.example.com,https://loyalty.example.com

# ─── Scripted E2E (optional, dangerous on real prod) ─────────────────
# API only: echoes inviteToken on POST /users/invite so RBAC automation can rotate roles without email.
# NEVER leave true on publicly reachable tenants.
# EXPOSE_INVITE_TOKENS=true

# ─── Database (PostgreSQL) ────────────────────────
# Docker Compose (docker/docker-compose.yml) maps host 5433 → Postgres in the container.
DATABASE_URL=postgresql://queueplatform:queueplatform@localhost:5433/queueplatform?sslmode=disable
# Optional: non-superuser runtime URL so PostgreSQL RLS policies apply (API only).
# Keep DATABASE_URL as the migration/admin superuser; set APP_DATABASE_URL after running:
#   APP_DATABASE_PASSWORD=... pnpm --filter @queueplatform/database setup:app-db-user
# APP_DATABASE_URL=postgresql://qms_app:...@localhost:5433/queueplatform?sslmode=disable
# Option B — Homebrew Postgres on macOS (no DB container): run `pnpm setup:local-brew`, then use
# port 5432 and your macOS username (peer/trust auth is typical for local TCP to 127.0.0.1):
# DATABASE_URL=postgresql://YOUR_MAC_USER@127.0.0.1:5432/queueplatform?sslmode=disable
# Connection-pool tuning (production): size the per-instance Prisma pool so multiple
# API replicas don't exhaust Postgres connections. Appended to the URL when set.
# Rule of thumb: connection_limit ≈ (max DB connections - reserved) / replica_count.
# DATABASE_CONNECTION_LIMIT=10
# DATABASE_POOL_TIMEOUT=10

# ─── Redis ────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# Option B — Homebrew Redis: same REDIS_URL (ensure `brew services start redis`).

# ─── Scheduled jobs (BullMQ) ──────────────────────
# Scheduled work (reminders, cleanup, health rollups) runs on a BullMQ queue:
# a repeatable dispatcher fires once cluster-wide and fans out tenant-scoped jobs
# that any API replica processes in parallel. Redis is required.
# SCHEDULED_JOBS_ENABLED=true        # set false to skip registering cron triggers
# SCHEDULED_JOBS_WORKER_ENABLED=true # set false to disable processing jobs in this instance
# SCHEDULED_JOBS_CONCURRENCY=5       # per-replica worker concurrency for tenant jobs

# ─── Reports / analytics ──────────────────────────
# Max span (days) allowed for a single report query; bounds DB scan size.
# MAX_REPORT_RANGE_DAYS=370

# ─── Display pairing ───────────────────────────────
# Pairing code lifetime (minutes) for TV-initiated and legacy admin codes.
# DISPLAY_CODE_EXPIRY_MINUTES=15
# Display session JWT lifetime (seconds); auto-refreshed via device API key in cookies.
# DISPLAY_TOKEN_TTL_SECONDS=86400

# ─── JWT ──────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-64-char-string
JWT_REFRESH_SECRET=change-me-to-another-random-64-char-string
# Access JWT lifetime (seconds). Web/admin session cookies use the same value.
JWT_ACCESS_TTL=14400
JWT_REFRESH_TTL=604800
# Platform impersonation access JWT lifetime (seconds); required for API bootstrap.
JWT_IMPERSONATION_TTL=900
# Per-request auth user lookup is cached in Redis for this many seconds to remove
# the hot-path DB query at scale. Suspension/role changes invalidate the cache on
# write; this TTL bounds staleness otherwise. Set 0 to disable caching entirely.
# AUTH_USER_CACHE_TTL_SECONDS=20

# ─── Centrifugo (Real-time) ──────────────────────
CENTRIFUGO_API_URL=http://localhost:8000/api
CENTRIFUGO_API_KEY=REDACTED_API_KEY
CENTRIFUGO_SECRET=REDACTED_SECRET
CENTRIFUGO_WEBHOOK_SECRET=REDACTED_WEBHOOK_SECRET

# ─── Security headers (web/admin) ─────────────────
# CSP_STRICT_MODE=1 removes script-src 'unsafe-inline' (enable after staging verification).
# CSP_REPORT_ONLY=1 emits Content-Security-Policy-Report-Only instead of enforcing.
# Local `pnpm dev` needs script-src 'unsafe-eval' (added automatically when NODE_ENV !== production).
# CSP_STRICT_MODE=0
# CSP_REPORT_ONLY=0

# ─── Queue session (API) ───────────────────────────
# Live line = tickets booked on or after branch-local midnight. Nightly job cancels older `waiting`.
# APP_QUEUE_CLOSE_PRIOR_SESSION_WAITING=false
# QUEUE_SESSION_FALLBACK_HOURS=36

# ─── Deploy / migrations ──────────────────────────
# Run migrations in a dedicated release step (recommended). Set true only for single-replica legacy start.
# RUN_DB_MIGRATIONS_ON_START=false
CENTRIFUGO_ADMIN_SECRET=REDACTED_ADMIN_SECRET

# ─── Email Provider ──────────────────────────────
# Local only: Mailpit (docker compose) — SMTP_HOST=localhost SMTP_PORT=1025; inbox http://localhost:8025
EMAIL_PROVIDER=smtp
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@queueplatform.com
# Default addresses live in packages/shared/src/constants/brand.ts (PRODUCT_NAME, DEFAULT_*_EMAIL).
# Production / real dev sends: the notifications worker uses Twilio SendGrid over HTTP when
# TWILIO_SENDGRID_API_KEY (or SENDGRID_API_KEY) is set — NOT the same secret as TWILIO_AUTH_TOKEN.
# TWILIO_SENDGRID_API_KEY=SG....
# TWILIO_SENDGRID_FROM_EMAIL=verified-sender@yourdomain.com
# (Optional) TWILIO_SENDGRID_FROM_NAME=QlessQ

# ─── SMS plan allowances (lifetime totals, not monthly) ─────────────────────
# Override per plan without redeploying code (API reads these when plan.limits has no smsCreditsTotal).
# Defaults in packages/shared/src/constants/sms-credits.ts: free=300, professional=5000, enterprise=25000
# SMS_CREDITS_FREE=300
# SMS_CREDITS_PROFESSIONAL=5000
# SMS_CREDITS_ENTERPRISE=25000

# One-time SMS packs (Checkout mode=payment). Requires STRIPE_SECRET_KEY below.
# Price IDs are optional — without them, checkout uses dynamic price_data from pack defaults.
# STRIPE_PRICE_SMS_500=price_xxx
# STRIPE_PRICE_SMS_2000=price_xxx
# STRIPE_PRICE_SMS_10000=price_xxx
# Optional message overrides: SMS_PACK_SMS_500=500
# SMS credits count only provider-accepted outbound SMS (Twilio SM… ids), not failed/invalid attempts.
# Pack retail tiers (USD): 500 @ $0.030, 2000 @ $0.0275, 10000 @ $0.025 — see SMS_CREDIT_PACKS in @queueplatform/shared.

# ─── SMS Provider ────────────────────────────────
# twilio (default) | kavenegar | generic | console
# Local dev without Twilio: set SMS_PROVIDER=console — outbound SMS is printed in the
# @queueplatform/notifications worker terminal (ensure `pnpm start` / turbo dev runs that package).
SMS_PROVIDER=twilio
# Twilio Console → Account Info. Never commit real values; copy this file to .env (gitignored).
TWILIO_ACCOUNT_SID=               # ACxxxx — from console.twilio.com
TWILIO_AUTH_TOKEN=                # Master auth token (or leave empty and use API Key below)
TWILIO_API_KEY=                   # SKxxxx — created by `twilio login` (preferred)
TWILIO_API_SECRET=                # API Key secret paired with TWILIO_API_KEY
TWILIO_PHONE_NUMBER=              # E.164 format, e.g. +19785030226
# Delivery status webhook — set to https://<api-host>/api/v1/notifications/webhook/twilio-status
TWILIO_STATUS_CALLBACK_URL=       # Set after deploy; empty disables status tracking

# When staff calls the next customer, SMS "almost ready" can go to the first N waiting tickets
# with customerPhone (default 3). Values above 3 are treated as 3 (hard cap). Dedupe is per ticket for 24h.
TICKET_ALMOST_READY_POSITION=3

# ─── File Storage ────────────────────────────────
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=./uploads

# ─── AI (optional, feature-flagged) ──────────────
AI_PROVIDER=none
AI_MODEL=
AI_API_KEY=

# Visit/session journeys — optional deployment overrides:
# - FEATURE_VISIT_JOURNEYS=false  → multi-step visits OFF for every organization (hard kill switch).
# - FEATURE_VISIT_JOURNEYS=true   → legacy: multi-step visits ON for every organization (org toggle ignored).
# - unset / other               → each organization enables multi-step under Dashboard → Organization (“Visit journeys”).
FEATURE_VISIT_JOURNEYS=false

# ─── Rate Limiting ───────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100
AUTH_THROTTLE_TTL=60
AUTH_THROTTLE_LIMIT=5

# ─── Encryption ──────────────────────────────────
ENCRYPTION_KEY=change-me-to-a-32-byte-hex-string

# ─── Stripe (Billing) ────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Stripe Price IDs — create Products+Prices in the Stripe dashboard, then paste the
# price_... IDs here. When set, checkout sessions use the saved Price objects instead
# of generating ad-hoc price_data on each request.
STRIPE_PRICE_ID_PROFESSIONAL_MONTHLY=price_...
STRIPE_PRICE_ID_PROFESSIONAL_YEARLY=price_...
STRIPE_PRICE_ID_ENTERPRISE_MONTHLY=price_...
STRIPE_PRICE_ID_ENTERPRISE_YEARLY=price_...

# ─── Frontend (Next.js public vars) ──────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_CENTRIFUGO_WS_URL=ws://localhost:8000/connection/websocket

# ─── Bootstrap QlessQ staff (optional) ────
# Local: pnpm db:bootstrap-admin (uses .env DATABASE_URL). Script: packages/api/scripts/bootstrap-platform-staff.ts
# Creates reserved org slug queueplatform-internal unless BOOTSTRAP_ORG_ID is set. See docs/guides/DATABASE_GUIDE.md
# Production: copy .env.production.example → .env.production, then pnpm db:bootstrap-admin:production
# BOOTSTRAP_ADMIN_EMAIL=parsa.admin@queueplatform.test
# BOOTSTRAP_ADMIN_PASSWORD=
# BOOTSTRAP_ORG_ID=
# Tenant role: admin (default) | viewer | staff | manager | owner — use viewer for QlessQ staff + ops UI
# BOOTSTRAP_SYSTEM_ROLE=viewer

# ─── QlessQ staff (cross-tenant ops / support) — API (optional) ───
# Break-glass or bootstrap only. Users in org slug queueplatform-internal (Admin → Admins) are operators without this.
# PLATFORM_OPERATOR_EMAILS=parsa.admin@queueplatform.test
# PLATFORM_OPERATOR_USER_IDS=

# ==============================================================================
# Sentry (Observability & Error Tracking)
# ==============================================================================
# Leave unset locally unless you want to test error tracking. When unset, Sentry is disabled.
#
# API + notification worker (server-side):
#   SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project>
#
# Next.js web (browser + server components):
#   NEXT_PUBLIC_SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project>
#   (Can match SENTRY_DSN; required for client-side capture.)
#
# Source map uploads on web production build (optional but recommended):
#   SENTRY_AUTH_TOKEN=...
#   SENTRY_ORG=your-org-slug
#   SENTRY_PROJECT=your-project-slug
#
# Release tag for Sentry (optional; Railway sets RAILWAY_GIT_COMMIT_SHA automatically).
# SENTRY_RELEASE=
# NEXT_PUBLIC_SENTRY_RELEASE=
#
# Production-only guard for GET /api/v1/health/sentry-test
# SENTRY_TEST_SECRET=
#
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=
