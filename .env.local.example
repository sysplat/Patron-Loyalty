# Local overrides (Homebrew Postgres + Redis). Copy to .env.local:
#   cp .env.local.example .env.local
#
# Used only by `pnpm dev:local` / `pnpm dev:full:local` (not loaded by default).
# Default dev (`pnpm dev:full`) uses Railway Postgres from `.env`.

# Required if your Mac Postgres asks for a password over TCP (common on Homebrew):
# LOCAL_PG_PASSWORD=your-postgres-password
DATABASE_URL=postgresql://YOUR_MAC_USER@127.0.0.1:5432/queueplatform?sslmode=disable
REDIS_URL=redis://127.0.0.1:6379
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

APP_URL=http://localhost:3001
API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_CENTRIFUGO_WS_URL=ws://localhost:8000/connection/websocket

CENTRIFUGO_API_URL=http://localhost:8000/api
CENTRIFUGO_API_KEY=centrifugo-api-key
CENTRIFUGO_SECRET=centrifugo-secret-key
CENTRIFUGO_ADMIN_SECRET=centrifugo-admin-secret
