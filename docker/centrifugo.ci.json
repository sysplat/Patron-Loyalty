{
  "client": {
    "token": {
      "hmac_secret_key": "ci-secret"
    },
    "allowed_origins": ["http://localhost:3001", "http://localhost:3002"]
  },
  "http_api": {
    "key": "ci-key"
  },
  "engine": {
    "type": "memory"
  },
  "channel": {
    "namespaces": [
      {
        "name": "queue",
        "presence": true,
        "history_size": 50,
        "history_ttl": "300s",
        "force_recovery": true,
        "allow_subscribe_for_client": true,
        "allow_publish_for_client": false
      },
      {
        "name": "display",
        "presence": true,
        "history_size": 100,
        "history_ttl": "600s",
        "force_recovery": true,
        "allow_subscribe_for_client": true,
        "allow_publish_for_client": false
      },
      {
        "name": "org",
        "presence": true,
        "history_size": 50,
        "history_ttl": "300s",
        "force_recovery": true,
        "allow_subscribe_for_client": true,
        "allow_publish_for_client": false
      },
      {
        "name": "notifications",
        "presence": false,
        "history_size": 20,
        "history_ttl": "120s",
        "force_recovery": true,
        "allow_subscribe_for_client": true,
        "allow_publish_for_client": false
      }
    ]
  },
  "health": {
    "enabled": true
  },
  "log": {
    "level": "warn"
  }
}
