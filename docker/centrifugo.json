{
  "client": {
    "token": {
      "hmac_secret_key": "local-dev-secret"
    },
    "allowed_origins": [
      "http://localhost:3000",
      "http://localhost:3001",
      "http://localhost:3002",
      "http://localhost:3003",
      "https://qms-web-production.up.railway.app",
      "https://qms-admin-production.up.railway.app",
      "https://pl-loyalty-production.up.railway.app"
    ]
  },
  "http_api": {
    "key": "local-dev-api-key"
  },
  "admin": {
    "enabled": true,
    "password": "local-dev-admin",
    "secret": "local-dev-admin-secret"
  },
  "engine": {
    "type": "redis",
    "redis": {
      "address": "redis://redis:6379"
    }
  },
  "channel": {
    "namespaces": [
      {
        "name": "queue",
        "presence": true,
        "history_size": 50,
        "history_ttl": "300s",
        "force_recovery": true,
        "join_leave": false,
        "force_push_join_leave": false,
        "allow_publish_for_subscriber": false,
        "allow_subscribe_for_client": true
      },
      {
        "name": "display",
        "presence": true,
        "history_size": 100,
        "history_ttl": "600s",
        "force_recovery": true,
        "join_leave": false,
        "force_push_join_leave": false,
        "allow_publish_for_subscriber": false,
        "allow_subscribe_for_client": true
      },
      {
        "name": "notifications",
        "presence": false,
        "history_size": 20,
        "history_ttl": "120s",
        "force_recovery": true,
        "allow_subscribe_for_client": true
      },
      {
        "name": "org",
        "presence": true,
        "history_size": 50,
        "history_ttl": "300s",
        "force_recovery": true,
        "allow_subscribe_for_client": true
      }
    ]
  },
  "health": {
    "enabled": true
  },
  "log": {
    "level": "info"
  }
}
