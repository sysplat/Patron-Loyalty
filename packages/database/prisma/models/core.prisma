// Layer: Core — org tenancy, auth, RBAC, branches, patrons, settings

model Organization {
  id                    String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                  String                  @db.VarChar(100)
  slug                  String                  @unique @db.VarChar(120)
  /// When true (and not globally disabled), kiosk/staff ticket issuance may attach tickets to multi-step visits per branch/service journey rules.
  visitJourneysEnabled  Boolean                 @default(false) @map("visit_journeys_enabled")
  /// When true, the appointments module is active for this org. Must be enabled by a platform operator; off by default.
  appointmentsEnabled   Boolean                 @default(false) @map("appointments_enabled")
  patronCrmEnabled      Boolean                 @default(false) @map("patron_crm_enabled")
  /// Commercial product: `qms` (queue only), `loyalty` (LMS only), `bundle` (both).
  productSku            String                  @default("qms") @map("product_sku") @db.VarChar(20)
  website               String?                 @db.VarChar(255)
  industry              String?                 @db.VarChar(50)
  timezone              String                  @default("UTC") @db.VarChar(50)
  country               String?                 @db.VarChar(2)
  logoUrl               String?                 @map("logo_url")
  onboardingStep        String                  @default("email_verification") @map("onboarding_step") @db.VarChar(30)
  createdAt             DateTime                @default(now()) @map("created_at")
  updatedAt             DateTime                @updatedAt @map("updated_at")
  stripeCustomerId      String?                 @map("stripe_customer_id") @db.VarChar(50)
  status                String                  @default("active") @db.VarChar(20)
  activityLogs          ActivityLog[]
  announcements         Announcement[]
  appointments          Appointment[]
  auditLogs             AuditLog[]
  branches              Branch[]
  customers             Customer[]
  customerSegments      CustomerSegment[]
  consentLedgerEntries  ConsentLedgerEntry[]
  desks                 Desk[]
  displayDevices        DisplayDevice[]
  displayThemes         DisplayTheme[]
  featureFlags          FeatureFlag[]
  fileUploads           FileUpload[]
  integrations          Integration[]
  invoices              Invoice[]
  notificationTemplates NotificationTemplate[]
  notifications         Notification[]
  onboardingProgress    OnboardingProgress[]
  orgHealthSnapshots    OrgHealthSnapshot[]
  queues                Queue[]
  flowTemplates         BranchFlowTemplate[]
  flowSteps             BranchFlowStep[]
  stationProfiles       StationProfile[]
  stationProfileQueues  StationProfileQueue[]
  agentSessions         AgentSession[]
  reviews               Review[]
  roles                 Role[]
  serviceCategories     ServiceCategory[]
  services              Service[]
  settings              Setting[]
  subscriptions         Subscription[]
  supportMessages       SupportMessage[]
  supportRequests       SupportRequest[]
  announcementStates    AnnouncementUserState[]
  tickets               Ticket[]
  visits                Visit[]
  users                 User[]
  webhookEndpoints      WebhookEndpoint[]
  smsCreditPurchases    SmsCreditPurchase[]
  universalSuppressions UniversalSuppression[]
  loyaltyProgram        LoyaltyProgram?
  loyaltyTiers          LoyaltyTier[]
  loyaltyRewards        LoyaltyReward[]
  loyaltyCoupons        LoyaltyCoupon[]
  loyaltyCampaigns      LoyaltyCampaign[]
  loyaltyEarnRules      LoyaltyEarnRule[]
  loyaltyBadges         LoyaltyBadge[]
  loyaltyChallenges     LoyaltyChallenge[]
  loyaltyGiftCards      LoyaltyGiftCard[]
  loyaltyAccounts       LoyaltyAccount[]
  crmTasks              CrmTask[]
  crmSupportTickets     CrmSupportTicket[]
  crmSalesOpportunities CrmSalesOpportunity[]
  loyaltyPosConnections       LoyaltyPosConnection[]
  loyaltyMarketingConnections LoyaltyMarketingConnection[]

  @@map("organizations")
}


model Account {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email            String            @unique @db.VarChar(255)
  passwordHash     String            @map("password_hash") @db.VarChar(255)
  emailVerified    Boolean           @default(false) @map("email_verified")
  phone            String?           @db.VarChar(20)
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  users            User[]
  legalAcceptances LegalAcceptance[]

  @@map("accounts")
}

model LegalAcceptance {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  accountId    String   @map("account_id") @db.Uuid
  documentType String   @map("document_type") @db.VarChar(30)
  version      String   @db.VarChar(20)
  acceptedAt   DateTime @default(now()) @map("accepted_at")
  ipAddress    String?  @map("ip_address") @db.VarChar(45)
  userAgent    String?  @map("user_agent")
  account      Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([accountId, documentType])
  @@map("legal_acceptances")
}

model User {
  id                         String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  accountId                  String?                 @map("account_id") @db.Uuid
  orgId                      String                  @map("org_id") @db.Uuid
  email                      String                  @db.VarChar(255)
  phone                      String?                 @db.VarChar(20)
  passwordHash               String                  @map("password_hash") @db.VarChar(255)
  firstName                  String?                 @map("first_name") @db.VarChar(50)
  lastName                   String?                 @map("last_name") @db.VarChar(50)
  avatarUrl                  String?                 @map("avatar_url")
  emailVerified              Boolean                 @default(false) @map("email_verified")
  phoneVerified              Boolean                 @default(false) @map("phone_verified")
  status                     String                  @default("pending_verification") @db.VarChar(30)
  language                   String?                 @db.VarChar(10)
  timezone                   String?                 @db.VarChar(50)
  lastLoginAt                DateTime?               @map("last_login_at")
  twoFactorSecret            String?                 @map("two_factor_secret") @db.VarChar(64)
  twoFactorEnabled           Boolean                 @default(false) @map("two_factor_enabled")
  twoFactorBackupHashes      Json?                   @map("two_factor_backup_hashes")
  /**
   * Separate TOTP for Platform Admin app (queueplatform-internal operators).
   */
  adminTwoFactorSecret       String?                 @map("admin_two_factor_secret") @db.VarChar(64)
  adminTwoFactorEnabled      Boolean                 @default(false) @map("admin_two_factor_enabled")
  adminTwoFactorBackupHashes Json?                   @map("admin_two_factor_backup_hashes")
  createdAt                  DateTime                @default(now()) @map("created_at")
  updatedAt                  DateTime                @updatedAt @map("updated_at")
  account                    Account?                @relation(fields: [accountId], references: [id], onDelete: Restrict)
  activityLogs               ActivityLog[]
  assignedAppointments       Appointment[]           @relation("AssignedStaff")
  auditLogs                  AuditLog[]
  assignedDesks              Desk[]                  @relation("AssignedUser")
  emailVerifications         EmailVerification[]
  fileUploads                FileUpload[]
  passwordResets             PasswordReset[]
  roleAssignments            RoleAssignment[]
  sessions                   Session[]
  supportMessages            SupportMessage[]
  announcementStates         AnnouncementUserState[]
  assignedSupportRequests    SupportRequest[]        @relation("SupportRequestAssignee")
  createdSupportRequests     SupportRequest[]        @relation("SupportRequestCreator")
  contactSupportRequests     SupportRequest[]        @relation("SupportRequestContact")
  servedTickets              Ticket[]                @relation("ServedBy")
  agentSessions              AgentSession[]
  assignedCrmTasks               CrmTask[]
  assignedCrmSupportTickets      CrmSupportTicket[]      @relation("CrmSupportTicketAssignee")
  assignedCrmSalesOpportunities  CrmSalesOpportunity[]   @relation("CrmSalesOpportunityAssignee")
  organization                   Organization            @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, email])
  @@unique([accountId, orgId])
  @@index([orgId])
  @@index([email])
  @@index([accountId])
  @@map("users")
}

model Role {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId           String           @map("org_id") @db.Uuid
  name            String           @db.VarChar(50)
  description     String?          @db.VarChar(255)
  isSystemRole    Boolean          @default(false) @map("is_system_role")
  createdAt       DateTime         @default(now()) @map("created_at")
  roleAssignments RoleAssignment[]
  rolePermissions RolePermission[]
  organization    Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, name])
  @@index([orgId])
  @@map("roles")
}

model Permission {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  resource        String           @db.VarChar(50)
  action          String           @db.VarChar(20)
  scope           String           @default("org") @db.VarChar(10)
  rolePermissions RolePermission[]

  @@unique([resource, action, scope])
  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roleId       String     @map("role_id") @db.Uuid
  permissionId String     @map("permission_id") @db.Uuid
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model RoleAssignment {
  id       String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId   String  @map("user_id") @db.Uuid
  roleId   String  @map("role_id") @db.Uuid
  branchId String? @map("branch_id") @db.Uuid
  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: Cascade)
  role     Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId, branchId])
  @@index([userId])
  @@map("role_assignments")
}

model Branch {
  id                               String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId                            String               @map("org_id") @db.Uuid
  name                             String               @db.VarChar(100)
  slug                             String               @db.VarChar(120)
  address                          String?              @db.VarChar(500)
  lat                              Float?
  lng                              Float?
  timezone                         String               @default("UTC") @db.VarChar(50)
  phone                            String?              @db.VarChar(20)
  email                            String?              @db.VarChar(255)
  status                           String               @default("active") @db.VarChar(30)
  /// Default customer journey model for this branch. Services may override this.
  defaultJourneyMode               String               @default("single_ticket") @map("default_journey_mode") @db.VarChar(30)
  mapData                          Json?                @map("map_data")
  /// When true, all waiting customers at this branch see the “complex case” notice on the public track page (agent-controlled).
  exceptionalCustomerNotice        Boolean              @default(false) @map("exceptional_customer_notice")
  /// Optional hint shown with the notice (e.g. extra delay in minutes).
  exceptionalCustomerNoticeMinutes Int?                 @map("exceptional_customer_notice_minutes")
  createdAt                        DateTime             @default(now()) @map("created_at")
  updatedAt                        DateTime             @updatedAt @map("updated_at")
  announcements                    Announcement[]
  appointments                     Appointment[]
  dateOverrides                    BranchDateOverride[]
  branchServices                   BranchService[]
  organization                     Organization         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  desks                            Desk[]
  displayDevices                   DisplayDevice[]
  queues                           Queue[]
  flowTemplates                    BranchFlowTemplate[]
  stationProfiles                  StationProfile[]
  reviews                          Review[]
  roleAssignments                  RoleAssignment[]
  tickets                          Ticket[]
  visits                           Visit[]
  workingHours                     WorkingHours[]
  agentSessions                    AgentSession[]

  @@unique([orgId, slug])
  @@index([orgId])
  @@map("branches")
}
model Setting {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId        String       @map("org_id") @db.Uuid
  key          String       @db.VarChar(100)
  value        Json
  scope        String       @default("org") @db.VarChar(10)
  scopeId      String?      @map("scope_id") @db.Uuid
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, key, scope, scopeId])
  @@index([orgId])
  @@map("settings")
}

model Integration {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId        String       @map("org_id") @db.Uuid
  type         String       @db.VarChar(30)
  config       Json
  status       String       @default("active") @db.VarChar(20)
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@map("integrations")
}

model WebhookEndpoint {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId           String       @map("org_id") @db.Uuid
  url             String       @db.VarChar(500)
  events          Json
  secret          String       @db.VarChar(255)
  status          String       @default("active") @db.VarChar(20)
  lastTriggeredAt DateTime?    @map("last_triggered_at")
  createdAt       DateTime     @default(now()) @map("created_at")
  organization    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@map("webhook_endpoints")
}

model Session {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash") @db.VarChar(255)
  ipAddress String?   @map("ip_address") @db.VarChar(45)
  userAgent String?   @map("user_agent") @db.VarChar(500)
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("sessions")
}

model EmailVerification {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  tokenHash  String    @map("token_hash") @db.VarChar(255)
  expiresAt  DateTime  @map("expires_at")
  verifiedAt DateTime? @map("verified_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@map("email_verifications")
}

model PasswordReset {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash") @db.VarChar(255)
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@map("password_resets")
}
model Customer {
  id                      String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId                   String  @map("org_id") @db.Uuid
  name                    String  @db.VarChar(100)
  email                   String? @db.VarChar(255)
  phone                   String? @db.VarChar(20)
  transactionalSmsAllowed Boolean @default(false) @map("transactional_sms_allowed")

  smsConsentSource        String?              @map("sms_consent_source") @db.VarChar(30)
  smsConsentVersion       String?              @map("sms_consent_version") @db.VarChar(30)
  marketingSmsConsent     String               @default("REVOKED") @map("marketing_sms_consent") @db.VarChar(30)
  marketingEmailConsent   String               @default("REVOKED") @map("marketing_email_consent") @db.VarChar(30)
  marketingConsentSource  String?              @map("marketing_consent_source") @db.VarChar(30)
  marketingConsentVersion String?              @map("marketing_consent_version") @db.VarChar(30)
  /// Loyalty profile fields — collected in loyalty app, not kiosk.
  birthday                DateTime?            @map("birthday") @db.Date
  gender                  String?              @db.VarChar(20)
  addressLine1            String?              @map("address_line1") @db.VarChar(255)
  city                    String?              @db.VarChar(100)
  region                  String?              @db.VarChar(100)
  postalCode              String?              @map("postal_code") @db.VarChar(20)
  country                 String?              @db.VarChar(2)
  /// QlessQ / connector patron id — indexed for O(1) integration lookups.
  externalId              String?              @map("external_id") @db.VarChar(255)
  metadata                Json?
  createdAt               DateTime             @default(now()) @map("created_at")
  updatedAt               DateTime             @updatedAt @map("updated_at")
  organization            Organization         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  consentLedgerEntries    ConsentLedgerEntry[]
  loyaltyAccount          LoyaltyAccount?
  crmTasks                CrmTask[]
  crmSupportTickets       CrmSupportTicket[]
  crmSalesOpportunities   CrmSalesOpportunity[]

  @@index([orgId])
  @@index([orgId, email])
  @@index([orgId, phone])
  @@unique([orgId, externalId])
  @@map("customers")
}

/// Saved patron CRM segment filters (preset segments are built-in; this stores custom named filters).
model CustomerSegment {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId        String       @map("org_id") @db.Uuid
  name         String       @db.VarChar(100)
  /// JSON filter: { preset?: string, branchId?: string, search?: string }
  filters      Json         @default("{}")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@map("customer_segments")
}
model OnboardingProgress {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId        String       @map("org_id") @db.Uuid
  step         String       @db.VarChar(30)
  completed    Boolean      @default(false)
  data         Json         @default("{}")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, step])
  @@map("onboarding_progress")
}

model FeatureFlag {
  id                String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name              String        @unique @db.VarChar(100)
  enabled           Boolean       @default(false)
  orgIds            Json          @default("[]") @map("org_ids")
  rolloutPercentage Int           @default(0) @map("rollout_percentage")
  createdAt         DateTime      @default(now()) @map("created_at")
  orgId             String?       @map("org_id") @db.Uuid
  organization      Organization? @relation(fields: [orgId], references: [id])

  @@map("feature_flags")
}
