// Layer: Billing — subscriptions, plans, invoices, payments

model Subscription {
  id                   String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId                String       @map("org_id") @db.Uuid
  planId               String       @map("plan_id") @db.Uuid
  status               String       @default("trialing") @db.VarChar(20)
  currentPeriodStart   DateTime     @map("current_period_start")
  currentPeriodEnd     DateTime     @map("current_period_end")
  trialEndsAt          DateTime?    @map("trial_ends_at")
  createdAt            DateTime     @default(now()) @map("created_at")
  updatedAt            DateTime     @updatedAt @map("updated_at")
  cancelAtPeriodEnd    Boolean      @default(false) @map("cancel_at_period_end")
  stripePriceId        String?      @map("stripe_price_id") @db.VarChar(100)
  stripeSubscriptionId String?      @map("stripe_subscription_id") @db.VarChar(100)
  invoices             Invoice[]
  organization         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  plan                 Plan         @relation(fields: [planId], references: [id])

  @@index([orgId])
  @@map("subscriptions")
}

model Plan {
  id                   String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                 String         @db.VarChar(50)
  slug                 String         @unique @db.VarChar(50)
  priceMonthly         Float          @map("price_monthly")
  priceYearly          Float          @map("price_yearly")
  features             Json           @default("{}")
  limits               Json           @default("{}")
  isActive             Boolean        @default(true) @map("is_active")
  createdAt            DateTime       @default(now()) @map("created_at")
  stripePriceIdMonthly String?        @map("stripe_price_id_monthly") @db.VarChar(100)
  stripePriceIdYearly  String?        @map("stripe_price_id_yearly") @db.VarChar(100)
  subscriptions        Subscription[]

  @@map("plans")
}

model Invoice {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId          String          @map("org_id") @db.Uuid
  subscriptionId String?         @map("subscription_id") @db.Uuid
  amount         Float
  currency       String          @default("USD") @db.VarChar(3)
  status         String          @default("draft") @db.VarChar(20)
  issuedAt       DateTime        @map("issued_at")
  dueAt          DateTime        @map("due_at")
  paidAt         DateTime?       @map("paid_at")
  createdAt      DateTime        @default(now()) @map("created_at")
  organization   Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  subscription   Subscription?   @relation(fields: [subscriptionId], references: [id])
  paymentRecords PaymentRecord[]

  @@index([orgId])
  @@map("invoices")
}

model PaymentRecord {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoiceId       String   @map("invoice_id") @db.Uuid
  paymentProvider String   @map("payment_provider") @db.VarChar(50)
  providerRef     String   @map("provider_ref") @db.VarChar(255)
  amount          Float
  status          String   @db.VarChar(20)
  metadata        Json?
  createdAt       DateTime @default(now()) @map("created_at")
  invoice         Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("payment_records")
}

model SmsCreditPurchase {
  id                      String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId                   String       @map("org_id") @db.Uuid
  packSlug                String       @map("pack_slug") @db.VarChar(30)
  messages                Int
  amountCents             Int          @map("amount_cents")
  currency                String       @default("USD") @db.VarChar(3)
  status                  String       @default("pending") @db.VarChar(20)
  stripeCheckoutSessionId String       @unique @map("stripe_checkout_session_id") @db.VarChar(100)
  createdAt               DateTime     @default(now()) @map("created_at")
  completedAt             DateTime?    @map("completed_at")
  organization            Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([orgId, status])
  @@map("sms_credit_purchases")
}
