// Layer: QMS services — catalog, branch assignments, branch hours

// Service catalog (QMS scheduling layer — future qms-services.prisma)

model Service {
  id                         String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId                      String           @map("org_id") @db.Uuid
  name                       String           @db.VarChar(100)
  slug                       String           @db.VarChar(120)
  description                String?
  durationMinutes            Int              @map("duration_minutes")
  categoryId                 String?          @map("category_id") @db.Uuid
  status                     String           @default("active") @db.VarChar(20)
  sortOrder                  Int              @default(0) @map("sort_order")
  createdAt                  DateTime         @default(now()) @map("created_at")
  updatedAt                  DateTime         @updatedAt @map("updated_at")
  queueEnabled               Boolean          @default(true) @map("queue_enabled")
  appointmentEnabled         Boolean          @default(false) @map("appointment_enabled")
  appointmentSlotInterval    Int?             @map("appointment_slot_interval")
  appointmentLeadTimeMinutes Int              @default(60) @map("appointment_lead_time_minutes")
  appointmentMaxAdvanceDays  Int              @default(30) @map("appointment_max_advance_days")
  appointmentBufferMinutes   Int              @default(0) @map("appointment_buffer_minutes")
  appointmentRequiresEmail   Boolean          @default(false) @map("appointment_requires_email")
  /// Optional org-wide override for customer journey mode for this service.
  journeyModeOverride        String?          @map("journey_mode_override") @db.VarChar(30)
  /// Optional instructional tip to show customers tracking this service.
  instructionalTip           String?          @map("instructional_tip") @db.VarChar(500)
  /// Optional icon representing this service.
  icon                       String?          @db.VarChar(50)
  /// Pessimistic minutes per customer turn (queue services). Required when queueEnabled (with serviceEstimateHighMinutes).
  serviceEstimateLowMinutes  Int              @default(5) @map("estimated_wait_margin_below_minutes")
  /// Optimistic minutes per customer turn (queue services).
  serviceEstimateHighMinutes Int              @default(15) @map("estimated_wait_margin_above_minutes")
  appointments               Appointment[]
  branchServices             BranchService[]
  queues                     Queue[]
  category                   ServiceCategory? @relation(fields: [categoryId], references: [id])
  organization               Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  subServices                SubService[]
  tickets                    Ticket[]
  flowSteps                  BranchFlowStep[]

  @@unique([orgId, slug])
  @@index([orgId])
  @@map("services")
}

model SubService {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  serviceId       String        @map("service_id") @db.Uuid
  name            String        @db.VarChar(100)
  description     String?
  durationMinutes Int?          @map("duration_minutes")
  sortOrder       Int           @default(0) @map("sort_order")
  status          String        @default("active") @db.VarChar(20)
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  appointments    Appointment[]
  service         Service       @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId])
  @@map("sub_services")
}

model ServiceCategory {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId        String       @map("org_id") @db.Uuid
  name         String       @db.VarChar(50)
  slug         String       @db.VarChar(60)
  icon         String?      @db.VarChar(50)
  sortOrder    Int          @default(0) @map("sort_order")
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  services     Service[]

  @@unique([orgId, slug])
  @@index([orgId])
  @@map("service_categories")
}

model BranchService {
  id                               String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branchId                         String  @map("branch_id") @db.Uuid
  serviceId                        String  @map("service_id") @db.Uuid
  isActive                         Boolean @default(true) @map("is_active")
  capacity                         Int?
  customServiceEstimateLowMinutes  Int?    @map("custom_estimated_wait_margin_below_minutes")
  customServiceEstimateHighMinutes Int?    @map("custom_estimated_wait_margin_above_minutes")
  /// Optional branch+service override for customer journey mode.
  journeyModeOverride              String? @map("journey_mode_override") @db.VarChar(30)
  branch                           Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  service                          Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([branchId, serviceId])
  @@map("branch_services")
}

model WorkingHours {
  id         String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branchId   String  @map("branch_id") @db.Uuid
  dayOfWeek  Int     @map("day_of_week")
  openTime   String  @map("open_time") @db.VarChar(5)
  closeTime  String  @map("close_time") @db.VarChar(5)
  isClosed   Boolean @default(false) @map("is_closed")
  breakStart String? @map("break_start") @db.VarChar(5)
  breakEnd   String? @map("break_end") @db.VarChar(5)
  branch     Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([branchId, dayOfWeek])
  @@map("working_hours")
}

model BranchDateOverride {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branchId   String   @map("branch_id") @db.Uuid
  date       DateTime @db.Date
  openTime   String?  @map("open_time") @db.VarChar(5)
  closeTime  String?  @map("close_time") @db.VarChar(5)
  isClosed   Boolean  @default(false) @map("is_closed")
  breakStart String?  @map("break_start") @db.VarChar(5)
  breakEnd   String?  @map("break_end") @db.VarChar(5)
  note       String?  @db.VarChar(255)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  branch     Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([branchId, date])
  @@index([branchId])
  @@map("branch_date_overrides")
}
