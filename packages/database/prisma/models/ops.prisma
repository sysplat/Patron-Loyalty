// Layer: Org & platform ops — support, audit, announcements, reviews, suppressions

model Review {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId         String       @map("org_id") @db.Uuid
  branchId      String?      @map("branch_id") @db.Uuid
  customerName  String       @map("customer_name") @db.VarChar(100)
  customerEmail String?      @map("customer_email") @db.VarChar(255)
  rating        Int
  comment       String?
  status        String       @default("pending") @db.VarChar(20)
  createdAt     DateTime     @default(now()) @map("created_at")
  branch        Branch?      @relation(fields: [branchId], references: [id])
  organization  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@map("reviews")
}

model SupportRequest {
  id                     String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId                  String           @map("org_id") @db.Uuid
  createdByUserId        String           @map("created_by_user_id") @db.Uuid
  /// Org member authorized to reply to QlessQ on this ticket (defaults to creator; reassignable by owner/admin).
  contactUserId          String           @map("contact_user_id") @db.Uuid
  assignedToUserId       String?          @map("assigned_to_user_id") @db.Uuid
  subject                String           @db.VarChar(200)
  category               String           @default("general") @db.VarChar(30)
  priority               String           @default("normal") @db.VarChar(20)
  status                 String           @default("open") @db.VarChar(20)
  hasUnreadTenantReply   Boolean          @default(false) @map("has_unread_tenant_reply")
  hasUnreadPlatformReply Boolean          @default(false) @map("has_unread_platform_reply")
  createdAt              DateTime         @default(now()) @map("created_at")
  updatedAt              DateTime         @updatedAt @map("updated_at")
  resolvedAt             DateTime?        @map("resolved_at")
  messages               SupportMessage[]
  assignedTo             User?            @relation("SupportRequestAssignee", fields: [assignedToUserId], references: [id])
  contact                User             @relation("SupportRequestContact", fields: [contactUserId], references: [id], onDelete: Cascade)
  createdBy              User             @relation("SupportRequestCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)
  organization           Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, createdAt])
  @@index([status, priority])
  @@index([assignedToUserId])
  @@index([contactUserId])
  @@map("support_requests")
}

model SupportMessage {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId            String         @map("org_id") @db.Uuid
  supportRequestId String         @map("support_request_id") @db.Uuid
  authorUserId     String         @map("author_user_id") @db.Uuid
  body             String
  isInternal       Boolean        @default(false) @map("is_internal")
  /// Visible to org members only; never sent to QlessQ platform support.
  isOrgInternal    Boolean        @default(false) @map("is_org_internal")
  createdAt        DateTime       @default(now()) @map("created_at")
  author           User           @relation(fields: [authorUserId], references: [id], onDelete: Cascade)
  organization     Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  supportRequest   SupportRequest @relation(fields: [supportRequestId], references: [id], onDelete: Cascade)

  @@index([supportRequestId, createdAt])
  @@index([orgId, createdAt])
  @@map("support_messages")
}

model PlatformAuditEvent {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")
  actorUserId  String?  @map("actor_user_id") @db.Uuid
  actorEmail   String?  @map("actor_email") @db.VarChar(255)
  eventType    String   @map("event_type") @db.VarChar(100)
  severity     String   @default("info") @db.VarChar(20)
  subjectOrgId String?  @map("subject_org_id") @db.Uuid
  metadata     Json?
  ipAddress    String?  @map("ip_address") @db.VarChar(45)
  userAgent    String?  @map("user_agent") @db.VarChar(500)

  @@index([createdAt(sort: Desc)])
  @@index([eventType, createdAt(sort: Desc)])
  @@map("platform_audit_events")
}

model OrgHealthSnapshot {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId        String       @map("org_id") @db.Uuid
  computedAt   DateTime     @default(now()) @map("computed_at")
  status       String       @db.VarChar(20)
  metrics      Json         @default("{}")
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, computedAt(sort: Desc)])
  @@index([status, computedAt(sort: Desc)])
  @@map("org_health_snapshots")
}

model PlatformExportJob {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  requestedById String   @map("requested_by_user_id") @db.Uuid
  type          String   @db.VarChar(40)
  status        String   @default("pending") @db.VarChar(20)
  resultKey     String?  @map("result_key") @db.VarChar(500)
  errorMessage  String?  @map("error_message")
  metadata      Json?

  @@index([status, createdAt(sort: Desc)])
  @@map("platform_export_jobs")
}

model PlatformAnnouncement {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title                 String   @db.VarChar(200)
  body                  String
  type                  String   @default("info") @db.VarChar(20)
  deliveryMode          String   @default("banner") @map("delivery_mode") @db.VarChar(20)
  dismissBehavior       String   @default("allowed") @map("dismiss_behavior") @db.VarChar(20)
  requireAcknowledgment Boolean  @default(false) @map("require_acknowledgment")
  isActive              Boolean  @default(true) @map("is_active")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@index([isActive, createdAt(sort: Desc)])
  @@map("platform_announcements")
}

model ActivityLog {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId        String       @map("org_id") @db.Uuid
  userId       String?      @map("user_id") @db.Uuid
  action       String       @db.VarChar(50)
  resourceType String       @map("resource_type") @db.VarChar(50)
  resourceId   String?      @map("resource_id") @db.Uuid
  metadata     Json?
  ipAddress    String?      @map("ip_address") @db.VarChar(45)
  userAgent    String?      @map("user_agent") @db.VarChar(500)
  createdAt    DateTime     @default(now()) @map("created_at")
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id])

  @@index([orgId, createdAt])
  @@index([userId])
  @@map("activity_logs")
}

model AuditLog {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId        String       @map("org_id") @db.Uuid
  userId       String?      @map("user_id") @db.Uuid
  action       String       @db.VarChar(30)
  tableName    String       @map("table_name") @db.VarChar(50)
  recordId     String       @map("record_id") @db.Uuid
  oldValues    Json?        @map("old_values")
  newValues    Json?        @map("new_values")
  createdAt    DateTime     @default(now()) @map("created_at")
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id])

  @@index([orgId, createdAt])
  @@index([tableName, recordId])
  @@map("audit_logs")
}





model FileUpload {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId        String       @map("org_id") @db.Uuid
  userId       String?      @map("user_id") @db.Uuid
  filename     String       @db.VarChar(255)
  mimeType     String       @map("mime_type") @db.VarChar(100)
  size         Int
  storagePath  String       @map("storage_path") @db.VarChar(500)
  entityType   String?      @map("entity_type") @db.VarChar(50)
  entityId     String?      @map("entity_id") @db.Uuid
  createdAt    DateTime     @default(now()) @map("created_at")
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id])

  @@index([orgId])
  @@map("file_uploads")
}


model Announcement {
  id                    String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId                 String       @map("org_id") @db.Uuid
  branchId              String?      @map("branch_id") @db.Uuid
  message               String       @db.VarChar(500)
  type                  String       @default("info") @db.VarChar(10)
  deliveryMode          String       @default("banner") @map("delivery_mode") @db.VarChar(20)
  dismissBehavior       String       @default("allowed") @map("dismiss_behavior") @db.VarChar(20)
  requireAcknowledgment Boolean      @default(false) @map("require_acknowledgment")
  displayOnScreen       Boolean      @default(true) @map("display_on_screen")
  activeFrom            DateTime?    @map("active_from")
  activeUntil           DateTime?    @map("active_until")
  createdAt             DateTime     @default(now()) @map("created_at")
  updatedAt             DateTime     @updatedAt @map("updated_at")
  branch                Branch?      @relation(fields: [branchId], references: [id])
  organization          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([branchId, displayOnScreen])
  @@map("announcements")
}

model AnnouncementUserState {
  id                  String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId              String       @map("user_id") @db.Uuid
  orgId               String       @map("org_id") @db.Uuid
  sourceType          String       @map("source_type") @db.VarChar(20)
  announcementId      String       @map("announcement_id") @db.Uuid
  announcementVersion String       @map("announcement_version") @db.VarChar(50)
  seenAt              DateTime?    @map("seen_at")
  dismissedAt         DateTime?    @map("dismissed_at")
  acknowledgedAt      DateTime?    @map("acknowledged_at")
  snoozedUntil        DateTime?    @map("snoozed_until")
  createdAt           DateTime     @default(now()) @map("created_at")
  updatedAt           DateTime     @updatedAt @map("updated_at")
  organization        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user                User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, sourceType, announcementId, announcementVersion])
  @@index([userId, orgId])
  @@index([sourceType, announcementId, announcementVersion])
  @@map("announcement_user_states")
}
model UniversalSuppression {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId        String?       @map("org_id") @db.Uuid
  contactHash  String        @map("contact_hash") @db.VarChar(64)
  channel      String        @db.VarChar(20)
  source       String        @db.VarChar(50)
  reason       String?       @db.VarChar(255)
  createdAt    DateTime      @default(now()) @map("created_at")
  organization Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, contactHash, channel])
  @@index([contactHash, channel])
  @@map("universal_suppressions")
}
