// Layer: loyalty + patron CRM (see docs/architecture/REPO_BOUNDARIES.md)

// ─── Patron Loyalty (LMS) ───────────────────────────────────────────────────

model LoyaltyProgram {
  id                  String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId               String            @unique @map("org_id") @db.Uuid
  enabled             Boolean           @default(true)
  pointsCurrencyName  String            @default("Points") @map("points_currency_name") @db.VarChar(50)
  defaultEarnPoints   Int               @default(10) @map("default_earn_points")
  referralBonusPoints Int               @default(50) @map("referral_bonus_points")
  referredBonusPoints Int               @default(25) @map("referred_bonus_points")
  pointsExpiryDays    Int?              @map("points_expiry_days")
  displayCurrencyCode String            @default("USD") @map("display_currency_code") @db.VarChar(3)
  defaultLocale       String            @default("en") @map("default_locale") @db.VarChar(10)
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")
  organization        Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  tiers               LoyaltyTier[]
  earnRules           LoyaltyEarnRule[]

  @@map("loyalty_programs")
}

model LoyaltyTier {
  id                String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId             String           @map("org_id") @db.Uuid
  programId         String           @map("program_id") @db.Uuid
  name              String           @db.VarChar(50)
  slug              String           @db.VarChar(30)
  minLifetimePoints Int              @default(0) @map("min_lifetime_points")
  sortOrder         Int              @default(0) @map("sort_order")
  color             String?          @db.VarChar(20)
  benefits          Json?
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")
  organization      Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  program           LoyaltyProgram   @relation(fields: [programId], references: [id], onDelete: Cascade)
  accounts          LoyaltyAccount[]

  @@unique([orgId, slug])
  @@index([orgId, programId])
  @@map("loyalty_tiers")
}

model LoyaltyAccount {
  id                   String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId                String                      @map("org_id") @db.Uuid
  customerId           String                      @unique @map("customer_id") @db.Uuid
  tierId               String?                     @map("tier_id") @db.Uuid
  pointsBalance        Int                         @default(0) @map("points_balance")
  lifetimePointsEarned Int                         @default(0) @map("lifetime_points_earned")
  lifetimePointsBurned Int                         @default(0) @map("lifetime_points_burned")
  referralCode         String                      @map("referral_code") @db.VarChar(20)
  totalVisits          Int                         @default(0) @map("total_visits")
  lifetimeValueCents   Int                         @default(0) @map("lifetime_value_cents")
  healthScore          Int                         @default(50) @map("health_score")
  churnRisk            String                      @default("low") @map("churn_risk") @db.VarChar(20)
  createdAt            DateTime                    @default(now()) @map("created_at")
  updatedAt            DateTime                    @updatedAt @map("updated_at")
  organization         Organization                @relation(fields: [orgId], references: [id], onDelete: Cascade)
  customer             Customer                    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tier                 LoyaltyTier?                @relation(fields: [tierId], references: [id], onDelete: SetNull)
  pointLedger          LoyaltyPointLedger[]
  redemptions          LoyaltyRedemption[]
  wallet               LoyaltyWallet?
  referralsMade        LoyaltyReferral[]           @relation("ReferrerAccount")
  referralReceived     LoyaltyReferral?            @relation("ReferredAccount")
  badges               CustomerBadge[]
  challengeProgress    CustomerChallengeProgress[]
  couponRedemptions    LoyaltyCouponRedemption[]
  campaignSends        LoyaltyCampaignSend[]
  giftCardsPurchased   LoyaltyGiftCard[]           @relation("GiftCardPurchaser")
  patronGamePlays      LoyaltyPatronGamePlay[]

  @@unique([orgId, referralCode])
  @@index([orgId])
  @@index([orgId, tierId])
  @@map("loyalty_accounts")
}

model LoyaltyPointLedger {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId        String         @map("org_id") @db.Uuid
  accountId    String         @map("account_id") @db.Uuid
  type         String         @db.VarChar(20)
  points       Int
  balanceAfter Int            @map("balance_after")
  sourceType   String?        @map("source_type") @db.VarChar(30)
  sourceId     String?        @map("source_id") @db.VarChar(100)
  description  String?        @db.VarChar(500)
  expiresAt    DateTime?      @map("expires_at")
  createdAt    DateTime       @default(now()) @map("created_at")
  account      LoyaltyAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([orgId, accountId, createdAt(sort: Desc)])
  @@index([accountId, type])
  @@map("loyalty_point_ledger")
}

model LoyaltyReward {
  id           String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId        String              @map("org_id") @db.Uuid
  name         String              @db.VarChar(100)
  description  String?             @db.VarChar(500)
  type         String              @default("DISCOUNT") @db.VarChar(30)
  pointsCost   Int                 @map("points_cost")
  stock        Int?
  active       Boolean             @default(true)
  validFrom    DateTime?           @map("valid_from")
  validUntil   DateTime?           @map("valid_until")
  imageUrl     String?             @map("image_url") @db.VarChar(500)
  metadata     Json?
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")
  organization Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  redemptions  LoyaltyRedemption[]

  @@index([orgId, active])
  @@map("loyalty_rewards")
}

model LoyaltyRedemption {
  id          String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId       String         @map("org_id") @db.Uuid
  accountId   String         @map("account_id") @db.Uuid
  rewardId    String         @map("reward_id") @db.Uuid
  pointsSpent Int            @map("points_spent")
  status      String         @default("pending") @db.VarChar(20)
  redeemedAt  DateTime       @default(now()) @map("redeemed_at")
  fulfilledAt DateTime?      @map("fulfilled_at")
  account     LoyaltyAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  reward      LoyaltyReward  @relation(fields: [rewardId], references: [id], onDelete: Cascade)

  @@index([orgId, accountId])
  @@map("loyalty_redemptions")
}

model LoyaltyCoupon {
  id               String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId            String                    @map("org_id") @db.Uuid
  code             String                    @db.VarChar(50)
  name             String                    @db.VarChar(100)
  type             String                    @default("PERCENT") @db.VarChar(20)
  value            Int
  minPurchaseCents Int?                      @map("min_purchase_cents")
  maxUses          Int?                      @map("max_uses")
  usedCount        Int                       @default(0) @map("used_count")
  active           Boolean                   @default(true)
  validFrom        DateTime?                 @map("valid_from")
  validUntil       DateTime?                 @map("valid_until")
  tierSlugs        Json                      @default("[]") @map("tier_slugs")
  createdAt        DateTime                  @default(now()) @map("created_at")
  updatedAt        DateTime                  @updatedAt @map("updated_at")
  organization     Organization              @relation(fields: [orgId], references: [id], onDelete: Cascade)
  redemptions      LoyaltyCouponRedemption[]

  @@unique([orgId, code])
  @@index([orgId, active])
  @@map("loyalty_coupons")
}

model LoyaltyCouponRedemption {
  id         String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId      String         @map("org_id") @db.Uuid
  couponId   String         @map("coupon_id") @db.Uuid
  accountId  String         @map("account_id") @db.Uuid
  redeemedAt DateTime       @default(now()) @map("redeemed_at")
  coupon     LoyaltyCoupon  @relation(fields: [couponId], references: [id], onDelete: Cascade)
  account    LoyaltyAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([orgId, couponId])
  @@map("loyalty_coupon_redemptions")
}

model LoyaltyWallet {
  id           String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId        String                     @map("org_id") @db.Uuid
  accountId    String                     @unique @map("account_id") @db.Uuid
  balanceCents Int                        @default(0) @map("balance_cents")
  currency     String                     @default("USD") @db.VarChar(3)
  createdAt    DateTime                   @default(now()) @map("created_at")
  updatedAt    DateTime                   @updatedAt @map("updated_at")
  account      LoyaltyAccount             @relation(fields: [accountId], references: [id], onDelete: Cascade)
  transactions LoyaltyWalletTransaction[]

  @@index([orgId])
  @@map("loyalty_wallets")
}

model LoyaltyWalletTransaction {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId        String        @map("org_id") @db.Uuid
  walletId     String        @map("wallet_id") @db.Uuid
  type         String        @db.VarChar(20)
  amountCents  Int           @map("amount_cents")
  balanceAfter Int           @map("balance_after")
  description  String?       @db.VarChar(500)
  sourceType   String?       @map("source_type") @db.VarChar(30)
  sourceId     String?       @map("source_id") @db.VarChar(100)
  createdAt    DateTime      @default(now()) @map("created_at")
  wallet       LoyaltyWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([orgId, walletId, createdAt(sort: Desc)])
  @@map("loyalty_wallet_transactions")
}

model LoyaltyReferral {
  id                  String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId               String          @map("org_id") @db.Uuid
  referrerAccountId   String          @map("referrer_account_id") @db.Uuid
  referredCustomerId  String          @map("referred_customer_id") @db.Uuid
  referredAccountId   String?         @unique @map("referred_account_id") @db.Uuid
  status              String          @default("pending") @db.VarChar(20)
  referrerBonusPoints Int             @default(0) @map("referrer_bonus_points")
  referredBonusPoints Int             @default(0) @map("referred_bonus_points")
  completedAt         DateTime?       @map("completed_at")
  createdAt           DateTime        @default(now()) @map("created_at")
  referrerAccount     LoyaltyAccount  @relation("ReferrerAccount", fields: [referrerAccountId], references: [id], onDelete: Cascade)
  referredAccount     LoyaltyAccount? @relation("ReferredAccount", fields: [referredAccountId], references: [id], onDelete: SetNull)

  @@index([orgId, referrerAccountId])
  @@map("loyalty_referrals")
}

model LoyaltyEarnRule {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId        String         @map("org_id") @db.Uuid
  programId    String         @map("program_id") @db.Uuid
  name         String         @db.VarChar(100)
  eventType    String         @map("event_type") @db.VarChar(40)
  points       Int
  active       Boolean        @default(true)
  conditions   Json           @default("{}")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  organization Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  program      LoyaltyProgram @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@index([orgId, eventType, active])
  @@map("loyalty_earn_rules")
}

model LoyaltyCampaign {
  id            String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId         String                @map("org_id") @db.Uuid
  name          String                @db.VarChar(100)
  channel       String                @db.VarChar(20)
  trigger       String                @db.VarChar(30)
  status        String                @default("draft") @db.VarChar(20)
  subject       String?               @db.VarChar(200)
  body          String?
  segmentPreset String?               @map("segment_preset") @db.VarChar(50)
  scheduledAt   DateTime?             @map("scheduled_at")
  sentCount     Int                   @default(0) @map("sent_count")
  createdAt     DateTime              @default(now()) @map("created_at")
  updatedAt     DateTime              @updatedAt @map("updated_at")
  organization  Organization          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  sends         LoyaltyCampaignSend[]

  @@index([orgId, status])
  @@map("loyalty_campaigns")
}

model LoyaltyCampaignSend {
  id         String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId      String          @map("org_id") @db.Uuid
  campaignId String          @map("campaign_id") @db.Uuid
  accountId  String          @map("account_id") @db.Uuid
  status     String          @default("queued") @db.VarChar(20)
  sentAt     DateTime?       @map("sent_at")
  error      String?         @db.VarChar(500)
  createdAt  DateTime        @default(now()) @map("created_at")
  campaign   LoyaltyCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  account    LoyaltyAccount  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([orgId, campaignId])
  @@map("loyalty_campaign_sends")
}

model LoyaltyBadge {
  id           String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId        String          @map("org_id") @db.Uuid
  name         String          @db.VarChar(100)
  description  String?         @db.VarChar(500)
  icon         String?         @db.VarChar(50)
  criteria     Json            @default("{}")
  active       Boolean         @default(true)
  createdAt    DateTime        @default(now()) @map("created_at")
  organization Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  awards       CustomerBadge[]

  @@index([orgId, active])
  @@map("loyalty_badges")
}

model CustomerBadge {
  id        String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId     String         @map("org_id") @db.Uuid
  accountId String         @map("account_id") @db.Uuid
  badgeId   String         @map("badge_id") @db.Uuid
  earnedAt  DateTime       @default(now()) @map("earned_at")
  account   LoyaltyAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  badge     LoyaltyBadge   @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([accountId, badgeId])
  @@map("customer_badges")
}

model LoyaltyChallenge {
  id           String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId        String                      @map("org_id") @db.Uuid
  name         String                      @db.VarChar(100)
  description  String?                     @db.VarChar(500)
  targetType   String                      @map("target_type") @db.VarChar(30)
  targetValue  Int                         @map("target_value")
  rewardPoints Int                         @default(0) @map("reward_points")
  startAt      DateTime?                   @map("start_at")
  endAt        DateTime?                   @map("end_at")
  active       Boolean                     @default(true)
  createdAt    DateTime                    @default(now()) @map("created_at")
  organization Organization                @relation(fields: [orgId], references: [id], onDelete: Cascade)
  progress     CustomerChallengeProgress[]

  @@index([orgId, active])
  @@map("loyalty_challenges")
}

model CustomerChallengeProgress {
  id          String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId       String           @map("org_id") @db.Uuid
  accountId   String           @map("account_id") @db.Uuid
  challengeId String           @map("challenge_id") @db.Uuid
  progress    Int              @default(0)
  completedAt DateTime?        @map("completed_at")
  account     LoyaltyAccount   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  challenge   LoyaltyChallenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@unique([accountId, challengeId])
  @@map("customer_challenge_progress")
}

model LoyaltyGiftCard {
  id                  String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId               String          @map("org_id") @db.Uuid
  code                String          @db.VarChar(30)
  initialBalanceCents Int             @map("initial_balance_cents")
  balanceCents        Int             @map("balance_cents")
  currency            String          @default("USD") @db.VarChar(3)
  purchaserAccountId  String?         @map("purchaser_account_id") @db.Uuid
  recipientEmail      String?         @map("recipient_email") @db.VarChar(255)
  active              Boolean         @default(true)
  expiresAt           DateTime?       @map("expires_at")
  createdAt           DateTime        @default(now()) @map("created_at")
  organization        Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  purchaserAccount    LoyaltyAccount? @relation("GiftCardPurchaser", fields: [purchaserAccountId], references: [id], onDelete: SetNull)

  @@unique([orgId, code])
  @@map("loyalty_gift_cards")
}

model CrmTask {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId        String       @map("org_id") @db.Uuid
  customerId   String       @map("customer_id") @db.Uuid
  title        String       @db.VarChar(200)
  description  String?
  status       String       @default("open") @db.VarChar(20)
  dueAt        DateTime?    @map("due_at")
  assigneeId   String?      @map("assignee_id") @db.Uuid
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  customer     Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  assignee     User?        @relation(fields: [assigneeId], references: [id], onDelete: SetNull)

  @@index([orgId, customerId])
  @@index([orgId, status, dueAt])
  @@map("crm_tasks")
}

model CrmSupportTicket {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId        String       @map("org_id") @db.Uuid
  customerId   String       @map("customer_id") @db.Uuid
  subject      String       @db.VarChar(200)
  description  String?
  priority     String       @default("normal") @db.VarChar(20)
  status       String       @default("open") @db.VarChar(20)
  assigneeId   String?      @map("assignee_id") @db.Uuid
  resolvedAt   DateTime?    @map("resolved_at")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  customer     Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  assignee     User?        @relation("CrmSupportTicketAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  @@index([orgId, customerId])
  @@index([orgId, status, priority])
  @@map("crm_support_tickets")
}

model CrmSalesOpportunity {
  id                String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId             String       @map("org_id") @db.Uuid
  customerId        String       @map("customer_id") @db.Uuid
  title             String       @db.VarChar(200)
  stage             String       @default("lead") @db.VarChar(30)
  valueCents        Int          @default(0) @map("value_cents")
  expectedCloseDate DateTime?    @map("expected_close_date") @db.Date
  notes             String?
  assigneeId        String?      @map("assignee_id") @db.Uuid
  closedAt          DateTime?    @map("closed_at")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")
  organization      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  customer          Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  assignee          User?        @relation("CrmSalesOpportunityAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  @@index([orgId, customerId])
  @@index([orgId, stage])
  @@map("crm_sales_opportunities")
}

model LoyaltyPatronGamePlay {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId         String         @map("org_id") @db.Uuid
  accountId     String         @map("account_id") @db.Uuid
  gameType      String         @map("game_type") @db.VarChar(30)
  resultLabel   String         @map("result_label") @db.VarChar(100)
  pointsAwarded Int            @default(0) @map("points_awarded")
  playedAt      DateTime       @default(now()) @map("played_at")
  account       LoyaltyAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([orgId, accountId, gameType, playedAt])
  @@map("loyalty_patron_game_plays")
}

model ConsentLedgerEntry {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId        String   @map("org_id") @db.Uuid
  customerId   String   @map("customer_id") @db.Uuid
  channel      String   @db.VarChar(10) // "sms" or "email"
  purpose      String   @db.VarChar(30) // "marketing"
  action       String   @db.VarChar(30) // "GRANTED", "REVOKED"
  source       String   @db.VarChar(50) // "kiosk", "booking"
  ipAddress    String?  @map("ip_address") @db.VarChar(45)
  userAgent    String?  @map("user_agent") @db.VarChar(500)
  legalVersion String?  @map("legal_version") @db.VarChar(30)
  createdAt    DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  customer     Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([orgId, customerId])
  @@index([customerId, channel, purpose])
  @@map("consent_ledger_entries")
}
