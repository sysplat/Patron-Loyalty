// Layer: QMS — queues, tickets, visits, appointments, display, branch flows, desks/stations

model Queue {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId               String    @map("org_id") @db.Uuid
  branchId            String    @map("branch_id") @db.Uuid
  serviceId           String    @map("service_id") @db.Uuid
  name                String    @db.VarChar(100)
  prefix              String    @db.VarChar(5)
  journeyModeOverride String?   @map("journey_mode_override") @db.VarChar(30)
  status              String    @default("closed") @db.VarChar(10)
  currentNumber       Int       @default(0) @map("current_number")
  nextTicketSeq       Int       @default(1) @map("next_ticket_seq")
  sessionOpenedAt     DateTime? @map("session_opened_at")
  sessionClosesAt     DateTime? @map("session_closes_at")
  maxCapacity         Int?      @map("max_capacity")
  autoCloseAt         String?   @map("auto_close_at") @db.VarChar(5)
  minServiceMinutes   Int       @default(5) @map("min_service_minutes")
  maxServiceMinutes   Int       @default(15) @map("max_service_minutes")
  /// The "Type" of this queue (e.g. Standard Service vs. Collection/Pick-up).
  stepRole            String?   @map("step_role") @db.VarChar(30)
  /// The "Rule" for how customers are called (e.g. In Order vs. Staff Choice).
  callingPolicy       String    @default("fifo") @map("calling_policy") @db.VarChar(30)
  /// Optional association with a specific flow template step.
  flowTemplateId      String?   @map("flow_template_id") @db.Uuid

  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")
  queueRules           QueueRule[]
  flowSteps            BranchFlowStep[]
  branch               Branch                @relation(fields: [branchId], references: [id], onDelete: Cascade)
  flowTemplate         BranchFlowTemplate?   @relation(fields: [flowTemplateId], references: [id], onDelete: SetNull)
  organization         Organization          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  service              Service               @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  tickets              Ticket[]
  primaryForProfiles   StationProfile[]      @relation("StationProfilePrimaryQueue")
  stationProfileQueues StationProfileQueue[]

  @@unique([branchId, prefix])
  @@index([orgId])
  @@index([branchId])
  @@index([branchId, serviceId])
  @@index([flowTemplateId])
  @@map("queues")
}

model QueueRule {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  queueId  String @map("queue_id") @db.Uuid
  ruleType String @map("rule_type") @db.VarChar(30)
  config   Json
  queue    Queue  @relation(fields: [queueId], references: [id], onDelete: Cascade)

  @@index([queueId])
  @@map("queue_rules")
}

model Visit {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId         String       @map("org_id") @db.Uuid
  branchId      String       @map("branch_id") @db.Uuid
  trackingToken String       @default(dbgenerated("gen_random_uuid()")) @map("tracking_token") @db.Uuid
  status        String       @default("active") @db.VarChar(20)
  source        String       @default("online") @db.VarChar(20)
  customerName  String?      @map("customer_name") @db.VarChar(100)
  customerPhone String?      @map("customer_phone") @db.VarChar(20)
  customerEmail String?      @map("customer_email") @db.VarChar(255)
  language      String?      @db.VarChar(10)
  metadata      Json?
  /// POS / receipt transaction number for the whole visit (required once captured on step 1).
  externalRef   String?      @map("external_ref") @db.VarChar(100)
  startedAt     DateTime     @default(now()) @map("started_at")
  completedAt   DateTime?    @map("completed_at")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  branch        Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  organization  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  tickets       Ticket[]

  @@unique([trackingToken])
  @@index([orgId])
  @@index([branchId])
  @@index([orgId, status])
  @@index([orgId, createdAt])
  @@index([orgId, customerPhone])
  @@map("visits")
}

model Ticket {
  id                      String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId                   String    @map("org_id") @db.Uuid
  visitId                 String?   @map("visit_id") @db.Uuid
  queueId                 String    @map("queue_id") @db.Uuid
  branchId                String    @map("branch_id") @db.Uuid
  serviceId               String    @map("service_id") @db.Uuid
  ticketNumber            Int       @default(autoincrement()) @map("ticket_number")
  displayNumber           String    @map("display_number") @db.VarChar(20)
  customerName            String?   @map("customer_name") @db.VarChar(100)
  customerPhone           String?   @map("customer_phone") @db.VarChar(20)
  customerEmail           String?   @map("customer_email") @db.VarChar(255)
  status                  String    @default("waiting") @db.VarChar(20)
  priority                Int       @default(0)
  position                Int?
  estimatedWaitMins       Int?      @map("estimated_wait_mins")
  estimatedRemainingMins  Int?      @map("estimated_remaining_mins")
  isExceptional           Boolean   @default(false) @map("is_exceptional")
  deskNumber              String?   @map("desk_number") @db.VarChar(20)
  servedByUserId          String?   @map("served_by_user_id") @db.Uuid
  source                  String    @default("online") @db.VarChar(10)
  bookedAt                DateTime  @default(now()) @map("booked_at")
  calledAt                DateTime? @map("called_at")
  servedAt                DateTime? @map("served_at")
  completedAt             DateTime? @map("completed_at")
  createdAt               DateTime  @default(now()) @map("created_at")
  customerId              String?   @map("customer_id") @db.Uuid
  language                String?   @db.VarChar(10)
  metadata                Json?
  note                    String?   @db.VarChar(500)
  legalHold               Boolean   @default(false) @map("legal_hold")
  transactionalSmsAllowed Boolean   @default(false) @map("transactional_sms_allowed")

  externalRef    String?             @map("external_ref") @db.VarChar(100)
  serviceMinutes Int?                @map("service_minutes")
  waitMinutes    Int?                @map("wait_minutes")
  /// Timestamp when the ticket was marked as "ready" for pick-up/collection.
  readyAt        DateTime?           @map("ready_at")
  /// The index of this ticket within the multi-step visit journey (e.g. 0 for first step).
  stepIndex      Int?                @map("step_index")
  branch         Branch              @relation(fields: [branchId], references: [id], onDelete: Cascade)
  organization   Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  queue          Queue               @relation(fields: [queueId], references: [id], onDelete: Cascade)
  visit          Visit?              @relation(fields: [visitId], references: [id], onDelete: SetNull)
  flowTemplateId String?             @map("flow_template_id") @db.Uuid
  flowTemplate   BranchFlowTemplate? @relation(fields: [flowTemplateId], references: [id], onDelete: SetNull)
  servedBy       User?               @relation("ServedBy", fields: [servedByUserId], references: [id])
  service        Service             @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([orgId, createdAt])
  @@index([orgId, bookedAt])
  @@index([orgId, completedAt])
  @@index([orgId, customerPhone])
  @@index([queueId, status])
  @@index([visitId])
  @@index([branchId, status])
  @@index([queueId, status, priority, bookedAt])
  @@index([queueId, status, readyAt, priority, bookedAt])
  @@index([orgId, queueId, status, bookedAt])
  @@map("tickets")
}

model Appointment {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId           String       @map("org_id") @db.Uuid
  branchId        String       @map("branch_id") @db.Uuid
  serviceId       String       @map("service_id") @db.Uuid
  customerName    String       @map("customer_name") @db.VarChar(100)
  customerEmail   String?      @map("customer_email") @db.VarChar(255)
  customerPhone   String?      @map("customer_phone") @db.VarChar(20)
  scheduledAt     DateTime     @map("scheduled_at")
  durationMinutes Int          @map("duration_minutes")
  status          String       @default("pending") @db.VarChar(20)
  notes           String?
  assignedUserId  String?      @map("assigned_user_id") @db.Uuid
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  subServiceId    String?      @map("sub_service_id") @db.Uuid
  assignedTo      User?        @relation("AssignedStaff", fields: [assignedUserId], references: [id])
  branch          Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  organization    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  service         Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  subService      SubService?  @relation(fields: [subServiceId], references: [id])

  @@index([orgId])
  @@index([orgId, customerPhone])
  @@index([branchId, scheduledAt])
  @@map("appointments")
}
model DisplayDevice {
  id               String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId            String        @map("org_id") @db.Uuid
  branchId         String?       @map("branch_id") @db.Uuid
  name             String        @db.VarChar(100)
  type             String        @db.VarChar(10)
  pairingCode      String?       @map("pairing_code") @db.VarChar(6)
  pairingExpiresAt DateTime?     @map("pairing_expires_at")
  sessionToken     String?       @unique @map("session_token") @db.VarChar(255)
  /// SHA-256 hash of the device's permanent API key (issued once during pairing).
  apiKeyHash       String?       @unique @map("api_key_hash") @db.VarChar(64)
  /// SHA-256 hash of the device fingerprint for optional hardware pinning.
  fingerprintHash  String?       @map("fingerprint_hash") @db.VarChar(64)
  status           String        @default("unpaired") @db.VarChar(20)
  themeId          String?       @map("theme_id") @db.Uuid
  lastSeenAt       DateTime?     @map("last_seen_at")
  config           Json          @default("{}")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")
  branch           Branch?       @relation(fields: [branchId], references: [id])
  organization     Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  theme            DisplayTheme? @relation(fields: [themeId], references: [id])

  @@index([orgId])
  @@index([pairingCode])
  @@map("display_devices")
}

model DisplayTheme {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId          String          @map("org_id") @db.Uuid
  name           String          @db.VarChar(100)
  type           String          @db.VarChar(10)
  config         Json
  isDefault      Boolean         @default(false) @map("is_default")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  displayDevices DisplayDevice[]
  organization   Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@map("display_themes")
}

model BranchFlowTemplate {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId           String           @map("org_id") @db.Uuid
  branchId        String           @map("branch_id") @db.Uuid
  name            String           @db.VarChar(100)
  description     String?          @db.VarChar(255)
  isActive        Boolean          @default(false) @map("is_active")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  steps           BranchFlowStep[]
  branch          Branch           @relation(fields: [branchId], references: [id], onDelete: Cascade)
  organization    Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  queues          Queue[]
  tickets         Ticket[]
  stationProfiles StationProfile[]

  @@index([branchId])
  @@map("branch_flow_templates")
}

model BranchFlowStep {
  id            String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId         String             @map("org_id") @db.Uuid
  templateId    String             @map("template_id") @db.Uuid
  stepIndex     Int                @map("step_index")
  deskNumber    String             @map("desk_number") @db.VarChar(20)
  serviceId     String             @map("service_id") @db.Uuid
  queueId       String?            @map("queue_id") @db.Uuid
  stepRole      String             @map("step_role") @db.VarChar(30)
  callingPolicy String             @map("calling_policy") @db.VarChar(30)
  template      BranchFlowTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  service       Service            @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  queue         Queue?             @relation(fields: [queueId], references: [id], onDelete: Cascade)
  organization  Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([templateId, stepIndex])
  @@index([orgId])
  @@map("branch_flow_steps")
}
model Desk {
  id                      String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId                   String          @map("org_id") @db.Uuid
  branchId                String          @map("branch_id") @db.Uuid
  name                    String          @db.VarChar(50)
  number                  String          @db.VarChar(20)
  status                  String          @default("closed") @db.VarChar(10)
  assignedUsers           User[]          @relation("AssignedUser")
  defaultStationProfileId String?         @map("default_station_profile_id") @db.Uuid
  createdAt               DateTime        @default(now()) @map("created_at")
  updatedAt               DateTime        @updatedAt @map("updated_at")
  defaultStationProfile   StationProfile? @relation("DeskDefaultStationProfile", fields: [defaultStationProfileId], references: [id], onDelete: SetNull)
  branch                  Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  organization            Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  agentSessions           AgentSession[]

  @@unique([branchId, number])
  @@index([orgId])
  @@index([branchId])
  @@map("desks")
}

/// Configurable station role (e.g. front counter vs pickup window) spanning one or more queues in a flow.
model StationProfile {
  id             String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId          String                @map("org_id") @db.Uuid
  branchId       String                @map("branch_id") @db.Uuid
  name           String                @db.VarChar(100)
  primaryQueueId String?               @map("primary_queue_id") @db.Uuid
  flowTemplateId String?               @map("flow_template_id") @db.Uuid
  isDefault      Boolean               @default(false) @map("is_default")
  createdAt      DateTime              @default(now()) @map("created_at")
  updatedAt      DateTime              @updatedAt @map("updated_at")
  branch         Branch                @relation(fields: [branchId], references: [id], onDelete: Cascade)
  organization   Organization          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  primaryQueue   Queue?                @relation("StationProfilePrimaryQueue", fields: [primaryQueueId], references: [id], onDelete: SetNull)
  flowTemplate   BranchFlowTemplate?   @relation(fields: [flowTemplateId], references: [id], onDelete: SetNull)
  queues         StationProfileQueue[]
  desks          Desk[]                @relation("DeskDefaultStationProfile")
  agentSessions  AgentSession[]

  @@index([orgId])
  @@index([branchId])
  @@index([flowTemplateId])
  @@map("station_profiles")
}

model StationProfileQueue {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId            String         @map("org_id") @db.Uuid
  stationProfileId String         @map("station_profile_id") @db.Uuid
  queueId          String         @map("queue_id") @db.Uuid
  sortOrder        Int            @default(0) @map("sort_order")
  visibilityOnly   Boolean        @default(false) @map("visibility_only")
  /// JSON array of capability strings: call, serve, complete, mark_ready, no_show, cancel, transfer
  capabilities     Json           @default("[]")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")
  stationProfile   StationProfile @relation(fields: [stationProfileId], references: [id], onDelete: Cascade)
  queue            Queue          @relation(fields: [queueId], references: [id], onDelete: Cascade)
  organization     Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([stationProfileId, queueId])
  @@index([orgId])
  @@index([queueId])
  @@map("station_profile_queues")
}

/// Server-side staff session for workbench context (desk + station profile).
model AgentSession {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId            String         @map("org_id") @db.Uuid
  userId           String         @map("user_id") @db.Uuid
  branchId         String         @map("branch_id") @db.Uuid
  deskId           String?        @map("desk_id") @db.Uuid
  deskNumber       String?        @map("desk_number") @db.VarChar(20)
  stationProfileId String         @map("station_profile_id") @db.Uuid
  endedAt          DateTime?      @map("ended_at")
  lastHeartbeatAt  DateTime       @default(now()) @map("last_heartbeat_at")
  surface          String         @default("classic") @db.VarChar(20)
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch           Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  desk             Desk?          @relation(fields: [deskId], references: [id], onDelete: SetNull)
  stationProfile   StationProfile @relation(fields: [stationProfileId], references: [id], onDelete: Cascade)
  organization     Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, userId, endedAt])
  @@index([branchId])
  @@map("agent_sessions")
}
