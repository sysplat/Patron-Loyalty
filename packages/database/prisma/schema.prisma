  data         Json         @default("{}")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, step])
  @@map("onboarding_progress")
}

model FeatureFlag {
  id                String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name              String        @unique @db.VarChar(100)
  enabled           Boolean       @default(false)
  orgIds            Json          @default("[]") @map("org_ids")
  rolloutPercentage Int           @default(0) @map("rollout_percentage")
  createdAt         DateTime      @default(now()) @map("created_at")
  orgId             String?       @map("org_id") @db.Uuid
  organization      Organization? @relation(fields: [orgId], references: [id])

  @@map("feature_flags")
}

model Announcement {
  id                    String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId                 String       @map("org_id") @db.Uuid
  branchId              String?      @map("branch_id") @db.Uuid
  message               String       @db.VarChar(500)
  type                  String       @default("info") @db.VarChar(10)
  deliveryMode          String       @default("banner") @map("delivery_mode") @db.VarChar(20)
  dismissBehavior       String       @default("allowed") @map("dismiss_behavior") @db.VarChar(20)
  requireAcknowledgment Boolean      @default(false) @map("require_acknowledgment")
  displayOnScreen       Boolean      @default(true) @map("display_on_screen")
  activeFrom            DateTime?    @map("active_from")
  activeUntil           DateTime?    @map("active_until")
  createdAt             DateTime     @default(now()) @map("created_at")
  updatedAt             DateTime     @updatedAt @map("updated_at")
  branch                Branch?      @relation(fields: [branchId], references: [id])
  organization          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([branchId, displayOnScreen])
  @@map("announcements")
}

model AnnouncementUserState {
  id                  String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId              String       @map("user_id") @db.Uuid
  orgId               String       @map("org_id") @db.Uuid
  sourceType          String       @map("source_type") @db.VarChar(20)
  announcementId      String       @map("announcement_id") @db.Uuid
  announcementVersion String       @map("announcement_version") @db.VarChar(50)
  seenAt              DateTime?    @map("seen_at")
  dismissedAt         DateTime?    @map("dismissed_at")
  acknowledgedAt      DateTime?    @map("acknowledged_at")
  snoozedUntil        DateTime?    @map("snoozed_until")
  createdAt           DateTime     @default(now()) @map("created_at")
  updatedAt           DateTime     @updatedAt @map("updated_at")
  organization        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user                User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, sourceType, announcementId, announcementVersion])
  @@index([userId, orgId])
  @@index([sourceType, announcementId, announcementVersion])
  @@map("announcement_user_states")
}

model Desk {
  id                      String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId                   String          @map("org_id") @db.Uuid
  branchId                String          @map("branch_id") @db.Uuid
  name                    String          @db.VarChar(50)
  number                  String          @db.VarChar(20)
  status                  String          @default("closed") @db.VarChar(10)
  assignedUsers           User[]          @relation("AssignedUser")
  defaultStationProfileId String?         @map("default_station_profile_id") @db.Uuid
  createdAt               DateTime        @default(now()) @map("created_at")
  updatedAt               DateTime        @updatedAt @map("updated_at")
  defaultStationProfile   StationProfile? @relation("DeskDefaultStationProfile", fields: [defaultStationProfileId], references: [id], onDelete: SetNull)
  branch                  Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  organization            Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  agentSessions           AgentSession[]

  @@unique([branchId, number])
  @@index([orgId])
  @@index([branchId])
  @@map("desks")
}

/// Configurable station role (e.g. front counter vs pickup window) spanning one or more queues in a flow.
model StationProfile {
  id             String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId          String                @map("org_id") @db.Uuid
  branchId       String                @map("branch_id") @db.Uuid
  name           String                @db.VarChar(100)
  primaryQueueId String?               @map("primary_queue_id") @db.Uuid
  flowTemplateId String?               @map("flow_template_id") @db.Uuid
  isDefault      Boolean               @default(false) @map("is_default")
  createdAt      DateTime              @default(now()) @map("created_at")
  updatedAt      DateTime              @updatedAt @map("updated_at")
  branch         Branch                @relation(fields: [branchId], references: [id], onDelete: Cascade)
  organization   Organization          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  primaryQueue   Queue?                @relation("StationProfilePrimaryQueue", fields: [primaryQueueId], references: [id], onDelete: SetNull)
  flowTemplate   BranchFlowTemplate?   @relation(fields: [flowTemplateId], references: [id], onDelete: SetNull)
  queues         StationProfileQueue[]
  desks          Desk[]                @relation("DeskDefaultStationProfile")
  agentSessions  AgentSession[]

  @@index([orgId])
  @@index([branchId])
  @@index([flowTemplateId])
  @@map("station_profiles")
}

model StationProfileQueue {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId            String         @map("org_id") @db.Uuid
  stationProfileId String         @map("station_profile_id") @db.Uuid
  queueId          String         @map("queue_id") @db.Uuid
  sortOrder        Int            @default(0) @map("sort_order")
  visibilityOnly   Boolean        @default(false) @map("visibility_only")
  /// JSON array of capability strings: call, serve, complete, mark_ready, no_show, cancel, transfer
  capabilities     Json           @default("[]")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")
  stationProfile   StationProfile @relation(fields: [stationProfileId], references: [id], onDelete: Cascade)
  queue            Queue          @relation(fields: [queueId], references: [id], onDelete: Cascade)
  organization     Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([stationProfileId, queueId])
  @@index([orgId])
  @@index([queueId])
  @@map("station_profile_queues")
}

/// Server-side staff session for workbench context (desk + station profile).
model AgentSession {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId            String         @map("org_id") @db.Uuid
  userId           String         @map("user_id") @db.Uuid
  branchId         String         @map("branch_id") @db.Uuid
  deskId           String?        @map("desk_id") @db.Uuid
  deskNumber       String?        @map("desk_number") @db.VarChar(20)
  stationProfileId String         @map("station_profile_id") @db.Uuid
  endedAt          DateTime?      @map("ended_at")
  lastHeartbeatAt  DateTime       @default(now()) @map("last_heartbeat_at")
  surface          String         @default("classic") @db.VarChar(20)
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch           Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  desk             Desk?          @relation(fields: [deskId], references: [id], onDelete: SetNull)
  stationProfile   StationProfile @relation(fields: [stationProfileId], references: [id], onDelete: Cascade)
  organization     Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, userId, endedAt])
  @@index([branchId])
  @@map("agent_sessions")
}

model UniversalSuppression {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId        String?       @map("org_id") @db.Uuid
  contactHash  String        @map("contact_hash") @db.VarChar(64)
  channel      String        @db.VarChar(20)
  source       String        @db.VarChar(50)
  reason       String?       @db.VarChar(255)
  createdAt    DateTime      @default(now()) @map("created_at")
  organization Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, contactHash, channel])
  @@index([contactHash, channel])
  @@map("universal_suppressions")
}
