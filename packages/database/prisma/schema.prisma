generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id                    String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                  String                  @db.VarChar(100)
  slug                  String                  @unique @db.VarChar(120)
  /// When true (and not globally disabled), kiosk/staff ticket issuance may attach tickets to multi-step visits per branch/service journey rules.
  visitJourneysEnabled  Boolean                 @default(false) @map("visit_journeys_enabled")
  /// When true, the appointments module is active for this org. Must be enabled by a platform operator; off by default.
  appointmentsEnabled   Boolean                 @default(false) @map("appointments_enabled")
  patronCrmEnabled      Boolean                 @default(false) @map("patron_crm_enabled")
  /// Commercial product: `qms` (queue only), `loyalty` (LMS only), `bundle` (both).
  productSku            String                  @default("qms") @map("product_sku") @db.VarChar(20)
  website               String?                 @db.VarChar(255)
  industry              String?                 @db.VarChar(50)
  timezone              String                  @default("UTC") @db.VarChar(50)
  country               String?                 @db.VarChar(2)
  logoUrl               String?                 @map("logo_url")
  onboardingStep        String                  @default("email_verification") @map("onboarding_step") @db.VarChar(30)
  createdAt             DateTime                @default(now()) @map("created_at")
  updatedAt             DateTime                @updatedAt @map("updated_at")
  stripeCustomerId      String?                 @map("stripe_customer_id") @db.VarChar(50)
  status                String                  @default("active") @db.VarChar(20)
  activityLogs          ActivityLog[]
  announcements         Announcement[]
  appointments          Appointment[]
  auditLogs             AuditLog[]
  branches              Branch[]
  customers             Customer[]
  customerSegments      CustomerSegment[]
  consentLedgerEntries  ConsentLedgerEntry[]
  desks                 Desk[]
  displayDevices        DisplayDevice[]
  displayThemes         DisplayTheme[]
  featureFlags          FeatureFlag[]
  fileUploads           FileUpload[]
  integrations          Integration[]
  invoices              Invoice[]
  notificationTemplates NotificationTemplate[]
  notifications         Notification[]
  onboardingProgress    OnboardingProgress[]
  orgHealthSnapshots    OrgHealthSnapshot[]
  queues                Queue[]
  flowTemplates         BranchFlowTemplate[]
  flowSteps             BranchFlowStep[]
  stationProfiles       StationProfile[]
  stationProfileQueues  StationProfileQueue[]
  agentSessions         AgentSession[]
  reviews               Review[]
  roles                 Role[]
  serviceCategories     ServiceCategory[]
  services              Service[]
  settings              Setting[]
  subscriptions         Subscription[]
  supportMessages       SupportMessage[]
  supportRequests       SupportRequest[]
  announcementStates    AnnouncementUserState[]
  tickets               Ticket[]
  visits                Visit[]
  users                 User[]
  webhookEndpoints      WebhookEndpoint[]
  smsCreditPurchases    SmsCreditPurchase[]
  universalSuppressions UniversalSuppression[]
  loyaltyProgram        LoyaltyProgram?
  loyaltyTiers          LoyaltyTier[]
  loyaltyRewards        LoyaltyReward[]
  loyaltyCoupons        LoyaltyCoupon[]
  loyaltyCampaigns      LoyaltyCampaign[]
  loyaltyEarnRules      LoyaltyEarnRule[]
  loyaltyBadges         LoyaltyBadge[]
  loyaltyChallenges     LoyaltyChallenge[]
  loyaltyGiftCards      LoyaltyGiftCard[]
  loyaltyAccounts       LoyaltyAccount[]
  crmTasks              CrmTask[]
  crmSupportTickets     CrmSupportTicket[]
  crmSalesOpportunities CrmSalesOpportunity[]

  @@map("organizations")
}

model SmsCreditPurchase {
  id                      String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId                   String       @map("org_id") @db.Uuid
  packSlug                String       @map("pack_slug") @db.VarChar(30)
  messages                Int
  amountCents             Int          @map("amount_cents")
  currency                String       @default("USD") @db.VarChar(3)
  status                  String       @default("pending") @db.VarChar(20)
  stripeCheckoutSessionId String       @unique @map("stripe_checkout_session_id") @db.VarChar(100)
  createdAt               DateTime     @default(now()) @map("created_at")
  completedAt             DateTime?    @map("completed_at")
  organization            Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([orgId, status])
  @@map("sms_credit_purchases")
}

model Account {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email            String            @unique @db.VarChar(255)
  passwordHash     String            @map("password_hash") @db.VarChar(255)
  emailVerified    Boolean           @default(false) @map("email_verified")
  phone            String?           @db.VarChar(20)
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  users            User[]
  legalAcceptances LegalAcceptance[]

  @@map("accounts")
}

model LegalAcceptance {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  accountId    String   @map("account_id") @db.Uuid
  documentType String   @map("document_type") @db.VarChar(30)
  version      String   @db.VarChar(20)
  acceptedAt   DateTime @default(now()) @map("accepted_at")
  ipAddress    String?  @map("ip_address") @db.VarChar(45)
  userAgent    String?  @map("user_agent")
  account      Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([accountId, documentType])
  @@map("legal_acceptances")
}

model User {
  id                         String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  accountId                  String?                 @map("account_id") @db.Uuid
  orgId                      String                  @map("org_id") @db.Uuid
  email                      String                  @db.VarChar(255)
  phone                      String?                 @db.VarChar(20)
  passwordHash               String                  @map("password_hash") @db.VarChar(255)
  firstName                  String?                 @map("first_name") @db.VarChar(50)
  lastName                   String?                 @map("last_name") @db.VarChar(50)
  avatarUrl                  String?                 @map("avatar_url")
  emailVerified              Boolean                 @default(false) @map("email_verified")
  phoneVerified              Boolean                 @default(false) @map("phone_verified")
  status                     String                  @default("pending_verification") @db.VarChar(30)
  language                   String?                 @db.VarChar(10)
  timezone                   String?                 @db.VarChar(50)
  lastLoginAt                DateTime?               @map("last_login_at")
  twoFactorSecret            String?                 @map("two_factor_secret") @db.VarChar(64)
  twoFactorEnabled           Boolean                 @default(false) @map("two_factor_enabled")
  twoFactorBackupHashes      Json?                   @map("two_factor_backup_hashes")
  /**
   * Separate TOTP for Platform Admin app (queueplatform-internal operators).
   */
  adminTwoFactorSecret       String?                 @map("admin_two_factor_secret") @db.VarChar(64)
  adminTwoFactorEnabled      Boolean                 @default(false) @map("admin_two_factor_enabled")
  adminTwoFactorBackupHashes Json?                   @map("admin_two_factor_backup_hashes")
  createdAt                  DateTime                @default(now()) @map("created_at")
  updatedAt                  DateTime                @updatedAt @map("updated_at")
  account                    Account?                @relation(fields: [accountId], references: [id], onDelete: Restrict)
  activityLogs               ActivityLog[]
  assignedAppointments       Appointment[]           @relation("AssignedStaff")
  auditLogs                  AuditLog[]
  assignedDesks              Desk[]                  @relation("AssignedUser")
  emailVerifications         EmailVerification[]
  fileUploads                FileUpload[]
  passwordResets             PasswordReset[]
  roleAssignments            RoleAssignment[]
  sessions                   Session[]
  supportMessages            SupportMessage[]
  announcementStates         AnnouncementUserState[]
  assignedSupportRequests    SupportRequest[]        @relation("SupportRequestAssignee")
  createdSupportRequests     SupportRequest[]        @relation("SupportRequestCreator")
  contactSupportRequests     SupportRequest[]        @relation("SupportRequestContact")
  servedTickets              Ticket[]                @relation("ServedBy")
  agentSessions              AgentSession[]
  assignedCrmTasks               CrmTask[]
  assignedCrmSupportTickets      CrmSupportTicket[]      @relation("CrmSupportTicketAssignee")
  assignedCrmSalesOpportunities  CrmSalesOpportunity[]   @relation("CrmSalesOpportunityAssignee")
  organization                   Organization            @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, email])
  @@unique([accountId, orgId])
  @@index([orgId])
  @@index([email])
  @@index([accountId])
  @@map("users")
}

model Role {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId           String           @map("org_id") @db.Uuid
  name            String           @db.VarChar(50)
  description     String?          @db.VarChar(255)
  isSystemRole    Boolean          @default(false) @map("is_system_role")
  createdAt       DateTime         @default(now()) @map("created_at")
  roleAssignments RoleAssignment[]
  rolePermissions RolePermission[]
  organization    Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, name])
  @@index([orgId])
  @@map("roles")
}

model Permission {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  resource        String           @db.VarChar(50)
  action          String           @db.VarChar(20)
  scope           String           @default("org") @db.VarChar(10)
  rolePermissions RolePermission[]

  @@unique([resource, action, scope])
  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roleId       String     @map("role_id") @db.Uuid
  permissionId String     @map("permission_id") @db.Uuid
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model RoleAssignment {
  id       String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId   String  @map("user_id") @db.Uuid
  roleId   String  @map("role_id") @db.Uuid
  branchId String? @map("branch_id") @db.Uuid
  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: Cascade)
  role     Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId, branchId])
  @@index([userId])
  @@map("role_assignments")
}

model Branch {
  id                               String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId                            String               @map("org_id") @db.Uuid
  name                             String               @db.VarChar(100)
  slug                             String               @db.VarChar(120)
  address                          String?              @db.VarChar(500)
  lat                              Float?
  lng                              Float?
  timezone                         String               @default("UTC") @db.VarChar(50)
  phone                            String?              @db.VarChar(20)
  email                            String?              @db.VarChar(255)
  status                           String               @default("active") @db.VarChar(30)
  /// Default customer journey model for this branch. Services may override this.
  defaultJourneyMode               String               @default("single_ticket") @map("default_journey_mode") @db.VarChar(30)
  mapData                          Json?                @map("map_data")
  /// When true, all waiting customers at this branch see the “complex case” notice on the public track page (agent-controlled).
  exceptionalCustomerNotice        Boolean              @default(false) @map("exceptional_customer_notice")
  /// Optional hint shown with the notice (e.g. extra delay in minutes).
  exceptionalCustomerNoticeMinutes Int?                 @map("exceptional_customer_notice_minutes")
  createdAt                        DateTime             @default(now()) @map("created_at")
  updatedAt                        DateTime             @updatedAt @map("updated_at")
  announcements                    Announcement[]
  appointments                     Appointment[]
  dateOverrides                    BranchDateOverride[]
  branchServices                   BranchService[]
  organization                     Organization         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  desks                            Desk[]
  displayDevices                   DisplayDevice[]
  queues                           Queue[]
  flowTemplates                    BranchFlowTemplate[]
  stationProfiles                  StationProfile[]
  reviews                          Review[]
  roleAssignments                  RoleAssignment[]
  tickets                          Ticket[]
  visits                           Visit[]
  workingHours                     WorkingHours[]
  agentSessions                    AgentSession[]

  @@unique([orgId, slug])
  @@index([orgId])
  @@map("branches")
}

model Service {
  id                         String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId                      String           @map("org_id") @db.Uuid
  name                       String           @db.VarChar(100)
  slug                       String           @db.VarChar(120)
  description                String?
  durationMinutes            Int              @map("duration_minutes")
  categoryId                 String?          @map("category_id") @db.Uuid
  status                     String           @default("active") @db.VarChar(20)
  sortOrder                  Int              @default(0) @map("sort_order")
  createdAt                  DateTime         @default(now()) @map("created_at")
  updatedAt                  DateTime         @updatedAt @map("updated_at")
  queueEnabled               Boolean          @default(true) @map("queue_enabled")
  appointmentEnabled         Boolean          @default(false) @map("appointment_enabled")
  appointmentSlotInterval    Int?             @map("appointment_slot_interval")
  appointmentLeadTimeMinutes Int              @default(60) @map("appointment_lead_time_minutes")
  appointmentMaxAdvanceDays  Int              @default(30) @map("appointment_max_advance_days")
  appointmentBufferMinutes   Int              @default(0) @map("appointment_buffer_minutes")
  appointmentRequiresEmail   Boolean          @default(false) @map("appointment_requires_email")
  /// Optional org-wide override for customer journey mode for this service.
  journeyModeOverride        String?          @map("journey_mode_override") @db.VarChar(30)
  /// Optional instructional tip to show customers tracking this service.
  instructionalTip           String?          @map("instructional_tip") @db.VarChar(500)
  /// Optional icon representing this service.
  icon                       String?          @db.VarChar(50)
  /// Pessimistic minutes per customer turn (queue services). Required when queueEnabled (with serviceEstimateHighMinutes).
  serviceEstimateLowMinutes  Int              @default(5) @map("estimated_wait_margin_below_minutes")
  /// Optimistic minutes per customer turn (queue services).
  serviceEstimateHighMinutes Int              @default(15) @map("estimated_wait_margin_above_minutes")
  appointments               Appointment[]
  branchServices             BranchService[]
  queues                     Queue[]
  category                   ServiceCategory? @relation(fields: [categoryId], references: [id])
  organization               Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  subServices                SubService[]
  tickets                    Ticket[]
  flowSteps                  BranchFlowStep[]

  @@unique([orgId, slug])
  @@index([orgId])
  @@map("services")
}

model SubService {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  serviceId       String        @map("service_id") @db.Uuid
  name            String        @db.VarChar(100)
  description     String?
  durationMinutes Int?          @map("duration_minutes")
  sortOrder       Int           @default(0) @map("sort_order")
  status          String        @default("active") @db.VarChar(20)
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  appointments    Appointment[]
  service         Service       @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId])
  @@map("sub_services")
}

model ServiceCategory {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId        String       @map("org_id") @db.Uuid
  name         String       @db.VarChar(50)
  slug         String       @db.VarChar(60)
  icon         String?      @db.VarChar(50)
  sortOrder    Int          @default(0) @map("sort_order")
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  services     Service[]

  @@unique([orgId, slug])
  @@index([orgId])
  @@map("service_categories")
}

model BranchService {
  id                               String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branchId                         String  @map("branch_id") @db.Uuid
  serviceId                        String  @map("service_id") @db.Uuid
  isActive                         Boolean @default(true) @map("is_active")
  capacity                         Int?
  customServiceEstimateLowMinutes  Int?    @map("custom_estimated_wait_margin_below_minutes")
  customServiceEstimateHighMinutes Int?    @map("custom_estimated_wait_margin_above_minutes")
  /// Optional branch+service override for customer journey mode.
  journeyModeOverride              String? @map("journey_mode_override") @db.VarChar(30)
  branch                           Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  service                          Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([branchId, serviceId])
  @@map("branch_services")
}

model WorkingHours {
  id         String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branchId   String  @map("branch_id") @db.Uuid
  dayOfWeek  Int     @map("day_of_week")
  openTime   String  @map("open_time") @db.VarChar(5)
  closeTime  String  @map("close_time") @db.VarChar(5)
  isClosed   Boolean @default(false) @map("is_closed")
  breakStart String? @map("break_start") @db.VarChar(5)
  breakEnd   String? @map("break_end") @db.VarChar(5)
  branch     Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([branchId, dayOfWeek])
  @@map("working_hours")
}

model BranchDateOverride {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branchId   String   @map("branch_id") @db.Uuid
  date       DateTime @db.Date
  openTime   String?  @map("open_time") @db.VarChar(5)
  closeTime  String?  @map("close_time") @db.VarChar(5)
  isClosed   Boolean  @default(false) @map("is_closed")
  breakStart String?  @map("break_start") @db.VarChar(5)
  breakEnd   String?  @map("break_end") @db.VarChar(5)
  note       String?  @db.VarChar(255)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  branch     Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([branchId, date])
  @@index([branchId])
  @@map("branch_date_overrides")
}

model Queue {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId               String    @map("org_id") @db.Uuid
  branchId            String    @map("branch_id") @db.Uuid
  serviceId           String    @map("service_id") @db.Uuid
  name                String    @db.VarChar(100)
  prefix              String    @db.VarChar(5)
  journeyModeOverride String?   @map("journey_mode_override") @db.VarChar(30)
  status              String    @default("closed") @db.VarChar(10)
  currentNumber       Int       @default(0) @map("current_number")
  nextTicketSeq       Int       @default(1) @map("next_ticket_seq")
  sessionOpenedAt     DateTime? @map("session_opened_at")
  sessionClosesAt     DateTime? @map("session_closes_at")
  maxCapacity         Int?      @map("max_capacity")
  autoCloseAt         String?   @map("auto_close_at") @db.VarChar(5)
  minServiceMinutes   Int       @default(5) @map("min_service_minutes")
  maxServiceMinutes   Int       @default(15) @map("max_service_minutes")
  /// The "Type" of this queue (e.g. Standard Service vs. Collection/Pick-up).
  stepRole            String?   @map("step_role") @db.VarChar(30)
  /// The "Rule" for how customers are called (e.g. In Order vs. Staff Choice).
  callingPolicy       String    @default("fifo") @map("calling_policy") @db.VarChar(30)
  /// Optional association with a specific flow template step.
  flowTemplateId      String?   @map("flow_template_id") @db.Uuid

  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")
  queueRules           QueueRule[]
  flowSteps            BranchFlowStep[]
  branch               Branch                @relation(fields: [branchId], references: [id], onDelete: Cascade)
  flowTemplate         BranchFlowTemplate?   @relation(fields: [flowTemplateId], references: [id], onDelete: SetNull)
  organization         Organization          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  service              Service               @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  tickets              Ticket[]
  primaryForProfiles   StationProfile[]      @relation("StationProfilePrimaryQueue")
  stationProfileQueues StationProfileQueue[]

  @@unique([branchId, prefix])
  @@index([orgId])
  @@index([branchId])
  @@index([branchId, serviceId])
  @@index([flowTemplateId])
  @@map("queues")
}

model QueueRule {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  queueId  String @map("queue_id") @db.Uuid
  ruleType String @map("rule_type") @db.VarChar(30)
  config   Json
  queue    Queue  @relation(fields: [queueId], references: [id], onDelete: Cascade)

  @@index([queueId])
  @@map("queue_rules")
}

model Visit {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId         String       @map("org_id") @db.Uuid
  branchId      String       @map("branch_id") @db.Uuid
  trackingToken String       @default(dbgenerated("gen_random_uuid()")) @map("tracking_token") @db.Uuid
  status        String       @default("active") @db.VarChar(20)
  source        String       @default("online") @db.VarChar(20)
  customerName  String?      @map("customer_name") @db.VarChar(100)
  customerPhone String?      @map("customer_phone") @db.VarChar(20)
  customerEmail String?      @map("customer_email") @db.VarChar(255)
  language      String?      @db.VarChar(10)
  metadata      Json?
  /// POS / receipt transaction number for the whole visit (required once captured on step 1).
  externalRef   String?      @map("external_ref") @db.VarChar(100)
  startedAt     DateTime     @default(now()) @map("started_at")
  completedAt   DateTime?    @map("completed_at")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  branch        Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  organization  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  tickets       Ticket[]

  @@unique([trackingToken])
  @@index([orgId])
  @@index([branchId])
  @@index([orgId, status])
  @@index([orgId, createdAt])
  @@index([orgId, customerPhone])
  @@map("visits")
}

model Ticket {
  id                      String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId                   String    @map("org_id") @db.Uuid
  visitId                 String?   @map("visit_id") @db.Uuid
  queueId                 String    @map("queue_id") @db.Uuid
  branchId                String    @map("branch_id") @db.Uuid
  serviceId               String    @map("service_id") @db.Uuid
  ticketNumber            Int       @default(autoincrement()) @map("ticket_number")
  displayNumber           String    @map("display_number") @db.VarChar(20)
  customerName            String?   @map("customer_name") @db.VarChar(100)
  customerPhone           String?   @map("customer_phone") @db.VarChar(20)
  customerEmail           String?   @map("customer_email") @db.VarChar(255)
  status                  String    @default("waiting") @db.VarChar(20)
  priority                Int       @default(0)
  position                Int?
  estimatedWaitMins       Int?      @map("estimated_wait_mins")
  estimatedRemainingMins  Int?      @map("estimated_remaining_mins")
  isExceptional           Boolean   @default(false) @map("is_exceptional")
  deskNumber              String?   @map("desk_number") @db.VarChar(20)
  servedByUserId          String?   @map("served_by_user_id") @db.Uuid
  source                  String    @default("online") @db.VarChar(10)
  bookedAt                DateTime  @default(now()) @map("booked_at")
  calledAt                DateTime? @map("called_at")
  servedAt                DateTime? @map("served_at")
  completedAt             DateTime? @map("completed_at")
  createdAt               DateTime  @default(now()) @map("created_at")
  customerId              String?   @map("customer_id") @db.Uuid
  language                String?   @db.VarChar(10)
  metadata                Json?
  note                    String?   @db.VarChar(500)
  legalHold               Boolean   @default(false) @map("legal_hold")
  transactionalSmsAllowed Boolean   @default(false) @map("transactional_sms_allowed")

  externalRef    String?             @map("external_ref") @db.VarChar(100)
  serviceMinutes Int?                @map("service_minutes")
  waitMinutes    Int?                @map("wait_minutes")
  /// Timestamp when the ticket was marked as "ready" for pick-up/collection.
  readyAt        DateTime?           @map("ready_at")
  /// The index of this ticket within the multi-step visit journey (e.g. 0 for first step).
  stepIndex      Int?                @map("step_index")
