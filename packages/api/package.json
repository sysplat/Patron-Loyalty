{
  "name": "@queueplatform/api",
  "version": "0.1.1",
  "description": "Queue Management System API",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "NODE_OPTIONS='--max-old-space-size=2048' nest start --watch",
    "start": "node dist/main",
    "start:worker": "node dist/worker",
    "start:debug": "nest start --debug --watch",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "typecheck": "tsc --noEmit",
    "bootstrap:platform-staff": "tsx scripts/bootstrap-platform-staff.ts",
    "backfill:accounts": "tsx scripts/backfill-accounts-from-users.ts"
  },
  "dependencies": {
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.24",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.24",
    "@nestjs/event-emitter": "^3.1.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.24",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^6.2.0",
    "@queueplatform/database": "workspace:*",
    "@queueplatform/shared": "workspace:*",
    "@sentry/node": "^10.55.0",
    "@sentry/profiling-node": "^10.55.0",
    "bcrypt": "^5.1.0",
    "bullmq": "^5.30.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.0",
    "luxon": "^3.7.2",
    "nestjs-zod": "^5.4.0",
    "otplib": "^12.0.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "stripe": "^22.0.0",
    "uuid": "^11.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/testing": "^11.1.24",
    "@types/bcrypt": "^5.0.0",
    "@types/express": "^5.0.0",
    "@types/luxon": "^3.7.1",
    "@types/passport-jwt": "^4.0.0",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "prisma": "^6.2.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.4.2",
    "vitest": "^3.2.4"
  }
}
