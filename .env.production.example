# Copy to .env.production (gitignored) and fill for one-off admin bootstrap against production.
# Usage from repo root: pnpm db:bootstrap-admin:production

NODE_ENV=production

# Production Postgres connection (same shape as deploy / hosting dashboard).
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# Required in production (no default in the script).
BOOTSTRAP_ADMIN_PASSWORD=change-me-strong-password

# Optional — defaults to parsa.admin@queueplatform.test
# BOOTSTRAP_ADMIN_EMAIL=parsa.admin@queueplatform.test

# Omit to bootstrap into reserved org slug queueplatform-internal (QP staff). Set to a UUID only for customer-org admin.
# BOOTSTRAP_ORG_ID=00000000-0000-0000-0000-000000000000

# BOOTSTRAP_FIRST_NAME=Parsa
# BOOTSTRAP_LAST_NAME=Admin
# Use viewer for internal staff if they should not get tenant admin (Users/Billing) UI.
# BOOTSTRAP_SYSTEM_ROLE=viewer

# QlessQ staff (production) — set to the same login email; restart API.
# PLATFORM_OPERATOR_EMAILS=parsa.admin@queueplatform.test
