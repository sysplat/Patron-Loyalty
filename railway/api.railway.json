{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "railway/docker/api.Dockerfile",
    "watchPatterns": [
      "package.json",
      "pnpm-lock.yaml",
      "pnpm-workspace.yaml",
      "tsconfig.base.json",
      "railway/docker/api.Dockerfile",
      ".dockerignore",
      "packages/api/**",
      "packages/shared/**",
      "packages/database/**",
      "railway/api.railway.json"
    ]
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "sh scripts/railway-api-start.sh",
    "healthcheckPath": "/api/v1/health/live",
    "healthcheckTimeout": 90,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
