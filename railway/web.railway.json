{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "railway/docker/web.Dockerfile",
    "watchPatterns": [
      "package.json",
      "pnpm-lock.yaml",
      "pnpm-workspace.yaml",
      "tsconfig.base.json",
      "railway/docker/web.Dockerfile",
      ".dockerignore",
      "railway/web.railway.json",
      "apps/web/**",
      "packages/shared/**",
      "packages/frontend-core/**"
    ]
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "node apps/web/server.js",
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 120,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
