# ─── QlessQ Loyalty App (apps/loyalty) ─────────────────────────────────────────
# Copy to apps/loyalty/.env.local for local overrides.

# Nest API (port 4000). Repo root `.env` API_URL is used for auth BFF + dev proxy.
# NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# Centrifugo WebSocket URL (optional; loyalty dashboard is mostly REST today)
# NEXT_PUBLIC_CENTRIFUGO_WS_URL=ws://localhost:8000/connection/websocket

# Tenant queue app — sidebar "Back to Queue Management" link
# NEXT_PUBLIC_WEB_URL=http://localhost:3000
