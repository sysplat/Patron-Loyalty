{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "railway/docker/admin.Dockerfile",
    "watchPatterns": [
      "package.json",
      "pnpm-lock.yaml",
      "pnpm-workspace.yaml",
      "tsconfig.base.json",
      "railway/docker/admin.Dockerfile",
      ".dockerignore",
      "railway.json",
      "apps/admin/**",
      "packages/shared/**"
    ]
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "node apps/admin/server.js",
    "healthcheckPath": "/",
    "healthcheckTimeout": 120,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
